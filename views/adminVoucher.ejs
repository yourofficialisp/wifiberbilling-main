        // Load and display voucher history for reprint
        function loadReprintVoucherHistory() {
            const voucherHistory = JSON.parse(localStorage.getItem('voucherPrintHistory') || '[]');
            const reprintList = document.getElementById('reprintVoucherList');
            
            if (!reprintList) return; // If element does not exist yet
            
            if (voucherHistory.length === 0) {
                reprintList.innerHTML = `
                    <div class="text-center text-muted">
                        <i class="bi bi-clock-history" style="font-size: 2rem;"></i>
                        <p class="mt-2">No voucher history available for reprinting</p>
                    </div>
                `;
                return;
            }
            
            let html = '<div class="row">';
            voucherHistory.forEach((voucherSet, index) => {
                const date = new Date(voucherSet.timestamp).toLocaleString('en-GB');
                const timeAgo = getTimeAgo(new Date(voucherSet.timestamp));
                
                html += `
                    <div class="col-md-6 mb-2">
                        <div class="card border-warning">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">${voucherSet.count} Voucher ${voucherSet.profile}</h6>
                                        <small class="text-muted">${date}</small>
                                        <br><small class="text-muted">${timeAgo}</small>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary reprint-voucher" data-voucher-set='${JSON.stringify(voucherSet)}' title="Reprint this voucher">
                                            <i class="bi bi-printer"></i>
                                        </button>
                                        <button class="btn btn-outline-danger delete-voucher-set" data-id="${voucherSet.id}" title="Delete from history">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            
            reprintList.innerHTML = html;
            
            // Add event listener for reprint buttons
            document.querySelectorAll('.reprint-voucher').forEach(btn => {
                btn.addEventListener('click', function() {
                    const voucherSet = JSON.parse(this.getAttribute('data-voucher-set'));
                    printVoucherSet(voucherSet);
                });
            });
            
            // Add event listener for delete buttons
            document.querySelectorAll('.delete-voucher-set').forEach(btn => {
                btn.addEventListener('click', function() {
                    const id = this.getAttribute('data-id');
                    deleteVoucherSet(id);
                });
            });
        }
        
        // Function to calculate time ago
        function getTimeAgo(date) {
            const now = new Date();
            const diffInSeconds = Math.floor((now - date) / 1000);
            
            if (diffInSeconds < 60) return 'Just now';
            if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)} minutes ago`;
            if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)} hours ago`;
            return `${Math.floor(diffInSeconds / 86400)} days ago`;
        }
        
        // Function to print voucher set
        function printVoucherSet(voucherSet) {
            window.voucherData = {
                vouchers: voucherSet.vouchers,
                profile: voucherSet.profile,
                price: voucherSet.price,
                namaHotspot: voucherSet.namaHotspot,
                adminKontak: voucherSet.adminKontak
            };
            
            showToast(`Opening print preview for ${voucherSet.count} ${voucherSet.profile} vouchers...`, 'info');
            setTimeout(() => {
                printVouchers();
            }, 500);
        }
        
        // Function to delete voucher set from history
        function deleteVoucherSet(id) {
            if (confirm('Are you sure you want to delete this voucher set from history?')) {
                const voucherHistory = JSON.parse(localStorage.getItem('voucherPrintHistory') || '[]');
                const filteredHistory = voucherHistory.filter(set => set.id != id);
                localStorage.setItem('voucherPrintHistory', JSON.stringify(filteredHistory));
                loadReprintVoucherHistory();
                showToast('Voucher set deleted from history', 'success');
            }
        }
        
        // Show toast notification
        function showToast(message, type = 'info') {
            const toastContainer = document.createElement('div');
            toastContainer.className = 'position-fixed top-0 end-0 p-3';
            toastContainer.style.zIndex = '1080';
            
            const toast = document.createElement('div');
            toast.className = `toast show bg-${type} text-white`;
            toast.setAttribute('role', 'alert');
            toast.setAttribute('aria-live', 'assertive');
            toast.setAttribute('aria-atomic', 'true');
            
            // Determine duration based on type
            let duration = 8000; // Default 8 seconds
            if (type === 'success') duration = 10000; // 10 seconds for success
            if (type === 'danger') duration = 12000; // 12 seconds for error
            if (type === 'warning') duration = 8000; // 8 seconds for warning
            
            toast.innerHTML = `
                <div class="toast-header bg-${type} text-white">
                    <strong class="me-auto">${type === 'success' ? 'Success' : type === 'danger' ? 'Error' : type === 'warning' ? 'Warning' : 'Info'}</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body">
                    ${message}
                </div>
            `;
            
            toastContainer.appendChild(toast);
            document.body.appendChild(toastContainer);
            
            // Auto remove after duration
            const autoHideTimer = setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toastContainer.remove(), 500);
            }, duration);
            
            // Add click event to close button
            toast.querySelector('.btn-close').addEventListener('click', () => {
                clearTimeout(autoHideTimer);
                toast.classList.remove('show');
                setTimeout(() => toastContainer.remove(), 500);
            });
            
            // Add click event to close on toast body click
            toast.querySelector('.toast-body').addEventListener('click', () => {
                clearTimeout(autoHideTimer);
                toast.classList.remove('show');
                setTimeout(() => toastContainer.remove(), 500);
            });
        }

        // Auto-hide notifications
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(alert => {
            setTimeout(() => {
                const fadeEffect = setInterval(() => {
                    if (!alert.style.opacity) {
                        alert.style.opacity = 1;
                    }
                    if (alert.style.opacity > 0) {
                        alert.style.opacity -= 0.1;
                    } else {
                        clearInterval(fadeEffect);
                        alert.remove();
                    }
                }, 100);
            }, 5000);
        });

        // Hamburger & sidebar logic
        const hamburger = document.getElementById('hamburgerBtn');
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        if (hamburger && sidebar && overlay) {
            hamburger.addEventListener('click', function() {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('show');
            });
            overlay.addEventListener('click', function() {
                sidebar.classList.remove('show');
                overlay.classList.remove('show');
            });
        }

        // Functions untuk Voucher Online Settings
        window.generateManualVoucher = function() {
            const username = document.getElementById('manualUsername').value.trim();
            const password = document.getElementById('manualPassword').value.trim();
            const profile = document.getElementById('manualProfileeeeeeeeee').value;

            if (!username || !password) {
                showToast('Username and password must be filled!', 'error');
                return;
            }

            // Generate voucher manual via AJAX
            fetch(addRouterIdToUrl('/admin/hotspot/generate-manual-voucher'), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(appendRouterIdToPostBody({
                    username: username,
                    password: password,
                    profile: profile
                }))
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(`Manual voucher successfully created: ${username}`, 'success');
                    // Clear form
                    document.getElementById('manualUsername').value = '';
                    document.getElementById('manualPassword').value = '';
                    // Reload page to refresh history
                    setTimeout(() => location.reload(), 2000);
                } else {
                    showToast('Failed to create voucher: ' + (data.message || 'Unknown error'), 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Error creating manual voucher', 'error');
            });
        };

        window.generateAutoVoucher = function() {
            const count = parseInt(document.getElementById('autoCount').value) || 1;
            const profile = document.getElementById('autoProfileeeeeeeeee').value;
            const isNumeric = document.getElementById('autoNumeric').checked;

            // Generate voucher otomatis via AJAX
            fetch(addRouterIdToUrl('/admin/hotspot/generate-auto-voucher'), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(appendRouterIdToPostBody({
                    count: count,
                    profile: profile,
                    numericOnly: isNumeric
                }))
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast(`${count} automatic vouchers successfully created`, 'success');
                    // Reload page to refresh history
                    setTimeout(() => location.reload(), 2000);
                } else {
                    showToast('Failed to create voucher: ' + (data.message || 'Unknown error'), 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Error creating automatic voucher', 'error');
            });
        };

        // Function to save online voucher settings
        window.saveVoucherOnlineSettings = function() {
            const settings = {};

            // Get settings from each package
            const packages = ['3k', '5k', '10k', '15k', '25k', '50k'];
            packages.forEach(pkg => {
                const nameElement = document.querySelector(`#online_${pkg}`).closest('.card').querySelector('.card-header h6');
                const profileInput = document.querySelector(`#online_${pkg}`).closest('.card').querySelector('input[type="text"]');
                const priceInput = document.querySelector(`#online_${pkg}`).closest('.card').querySelector('input[type="number"]');
                const enabledCheckbox = document.getElementById(`online_${pkg}`);

                if (profileInput && enabledCheckbox) {
                    settings[pkg] = {
                        name: nameElement ? nameElement.textContent : `${pkg} - Package`,
                        profile: profileInput.value,
                        price: priceInput ? parseInt(priceInput.value) : 0,
                        enabled: enabledCheckbox.checked
                    };
                }
            });

            // Save via AJAX
            fetch(addRouterIdToUrl('/admin/hotspot/save-voucher-online-settings-from-voucher'), {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(appendRouterIdToPostBody({ settings: settings }))
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('Setting voucher online saved successfully!', 'success');
                } else {
                    showToast('Failed to save settings: ' + (data.message || 'Unknown error'), 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showToast('Error saving online voucher settings', 'error');
            });
        };
    });
    </script>
</body>
</html>
