<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer Dashboard | ISP Portal</title>
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#0B1437">
  <link rel="apple-touch-icon" href="/img/icons/icon-192.png">
  <link rel="stylesheet" href="/css/pwa.css">
  <link rel="stylesheet" href="/css/customer-responsive.css">
  <script defer src="/js/pwa-install.js"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
  <style>
    :root {
      --primary-color: #4361ee;
      --secondary-color: #3f37c9;
      --accent-color: #4895ef;
      --success-color: #4cc9f0;
      --warning-color: #f72585;
      --info-color: #560bad;
      --light-color: #f8f9fa;
      --dark-color: #212529;
      --card-border-radius: 16px;
      --btn-border-radius: 50px;
      --transition-speed: 0.3s;
    }
    
    body {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      min-height: 100vh;
      color: var(--dark-color);
      line-height: 1.6;
    }
    
    /* Navbar Styling */
    .navbar {
      background: rgba(255, 255, 255, 0.95) !important;
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      box-shadow: 0 2px 15px rgba(0, 0, 0, 0.05);
    }
    
    .navbar-brand {
      font-weight: 700;
      color: var(--primary-color) !important;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .navbar-brand img {
      height: 40px;
      max-width: 80px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
      transition: transform var(--transition-speed);
    }
    
    .navbar-brand:hover img {
      transform: scale(1.05);
    }
    
    .status-badge {
      padding: 6px 12px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 600;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    }
    
    .btn-nav {
      border-radius: var(--btn-border-radius);
      font-size: 14px;
      font-weight: 500;
      transition: all var(--transition-speed) ease;
      padding: 8px 16px;
    }
    
    .btn-nav:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }
    
    /* Main Container */
    .main-container {
      padding: 30px 0;
      display: flex;
      flex-direction: column;
    }
    
    /* Display order - Billing on top */
    .form-section[style*="order: -1"] {
      order: -1;
    }
    
    .table-container[style*="order: -1"] {
      order: -1;
    }
    
    /* Card Styling */
    .card {
      border: none;
      border-radius: var(--card-border-radius);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      transition: all var(--transition-speed) ease;
      overflow: hidden;
      margin-bottom: 25px;
    }
    
    .card:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    }
    
    .card-header {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      color: white;
      border: none;
      padding: 25px;
      position: relative;
      overflow: hidden;
    }
    
    .card-header::before {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.1);
      transform: rotate(45deg);
      pointer-events: none;
    }
    
    .card-header h5 {
      font-weight: 700;
      letter-spacing: -0.5px;
      margin: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    /* Stats Grid Styling */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr); /* default desktop */
      gap: 20px;
      margin-bottom: 30px;
    }
    
    .stat-card {
      background: white;
      border-radius: var(--card-border-radius);
      padding: 20px;
      text-align: left;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.03);
      transition: all var(--transition-speed) ease;
      display: flex;
      align-items: center;
      gap: 15px;
      position: relative;
      overflow: hidden;
      border-left: 4px solid transparent;
    }
    
    .stat-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
      pointer-events: none;
    }
    
    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }
    
    .stat-card.online {
      border-left-color: var(--success-color);
    }
    
    .stat-card.offline {
      border-left-color: var(--dark-color);
    }
    
    .stat-icon {
      width: 50px;
      height: 50px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      color: white;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
      transition: all var(--transition-speed) ease;
      flex-shrink: 0;
    }
    
    .stat-card:hover .stat-icon {
      transform: scale(1.1);
    }
    
    .stat-content {
      flex-grow: 1;
    }
    
    .stat-icon.online { background: linear-gradient(135deg, #4cc9f0, #4895ef); }
    .stat-icon.offline { background: linear-gradient(135deg, #6c757d, #495057); }
    .stat-icon.wifi { background: linear-gradient(135deg, #4895ef, #3f37c9); }
    .stat-icon.cpu { background: linear-gradient(135deg, #f72585, #b5179e); }
    .stat-icon.clock { background: linear-gradient(135deg, #7209b7, #560bad); }
    .stat-icon.activity { background: linear-gradient(135deg, #4cc9f0, #4361ee); }
    .stat-icon.globe { background: linear-gradient(135deg, #4361ee, #3a0ca3); }
    .stat-icon.person { background: linear-gradient(135deg, #f72585, #7209b7); }
    .stat-icon.people { background: linear-gradient(135deg, #4895ef, #4cc9f0); }
    
    .stat-label {
      font-size: 12px;
      color: #6c757d;
      margin-bottom: 5px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .stat-value {
      font-size: 16px;
      font-weight: 700;
      color: var(--dark-color);
      margin: 0;
      line-height: 1.2;
    }
    
    .stat-badge {
      padding: 4px 10px;
      border-radius: 50px;
      font-size: 12px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    /* Form Sections Styling */
    .form-section {
      background: white;
      border-radius: var(--card-border-radius);
      padding: 25px;
      margin-bottom: 25px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.03);
      transition: all var(--transition-speed) ease;
      position: relative;
      overflow: hidden;
    }
    
    .form-section:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }
    
    .form-section::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 5px;
      height: 100%;
      background: linear-gradient(to bottom, var(--primary-color), var(--secondary-color));
      opacity: 0;
      transition: opacity var(--transition-speed) ease;
    }
    
    .form-section:hover::after {
      opacity: 1;
    }
    
    .form-section h6 {
      margin-bottom: 20px;
      font-weight: 700;
      color: var(--dark-color);
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 16px;
    }
    
    .form-section h6 i {
      color: var(--primary-color);
      font-size: 18px;
    }
    
    .input-group-responsive {
      display: flex;
      flex-wrap: wrap;
      gap: 15px;
    }
    
    .form-control {
      border-radius: var(--btn-border-radius);
      padding: 12px 20px;
      border: 1px solid rgba(0, 0, 0, 0.1);
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.02);
      transition: all var(--transition-speed) ease;
    }
    
    .form-control:focus {
      box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.15);
      border-color: var(--primary-color);
    }
    
    .btn-action {
      padding: 12px 20px;
      border-radius: var(--btn-border-radius);
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: all var(--transition-speed) ease;
      border: none;
      position: relative;
      overflow: hidden;
      z-index: 1;
    }
    
    .btn-action::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.1);
      transform: translateX(-100%);
      transition: transform 0.6s ease;
      z-index: -1;
    }
    
    .btn-action:hover::before {
      transform: translateX(0);
    }
    
    .btn-action:hover {
      transform: translateY(-3px);
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.15);
    }
    
    .btn-action:active {
      transform: translateY(-1px);
    }
    
    .btn-ssid {
      background: linear-gradient(135deg, #4895ef, #3f37c9);
      color: white;
    }
    
    .btn-password {
      background: linear-gradient(135deg, #7209b7, #560bad);
      color: white;
    }
    
    .btn-restart {
      background: linear-gradient(135deg, #f72585, #b5179e);
      color: white;
    }
    
    .text-muted {
      font-size: 13px;
      opacity: 0.8;
    }
    .btn-restart:hover {
      background: linear-gradient(135deg, #c82333 0%, #a71e2a 100%);
      color: white;
    }
    /* Table Container Styling */
    .table-container {
      background: white;
      border-radius: var(--card-border-radius);
      padding: 25px;
      margin-bottom: 25px;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.03);
      transition: all var(--transition-speed) ease;
      position: relative;
      overflow: hidden;
    }
    
    .table-container:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    }
    
    .table-container::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 5px;
      height: 100%;
      background: linear-gradient(to bottom, var(--accent-color), var(--info-color));
      opacity: 0;
      transition: opacity var(--transition-speed) ease;
    }
    
    .table-container:hover::after {
      opacity: 1;
    }
    
    .table-container h6 {
      color: var(--dark-color);
      font-weight: 700;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 16px;
    }
    
    .table-container h6 i {
      color: var(--accent-color);
      font-size: 18px;
    }
    .table td {
      border: none;
      padding: 12px 8px;
      font-size: 13px;
      vertical-align: middle;
    }
    .table tbody tr {
      border-bottom: 1px solid #f1f3f4;
    }
    .table tbody tr:hover {
      background: #f8f9fa;
    }
    .alert {
      border-radius: 12px;
      border: none;
      padding: 15px 20px;
    }
    .alert-success {
      background: rgba(40, 167, 69, 0.1);
      color: #155724;
      border-left: 4px solid #28a745;
    }
    .alert-warning {
      background: rgba(255, 193, 7, 0.1);
      color: #856404;
      border-left: 4px solid #ffc107;
    }
    .alert-info {
      background: rgba(102, 126, 234, 0.1);
      color: #2c3e50;
      border-left: 4px solid #667eea;
    }
    .footer {
      text-align: center;
      color: #6c757d;
      font-size: 12px;
      margin-top: 30px;
      padding: 20px 0;
    }
    @media (max-width: 768px) {
      .main-container {
        padding: 15px 0;
      }
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
      }
      .stat-card {
        padding: 15px 10px;
      }
      .form-section, .table-container {
        padding: 20px;
        margin-bottom: 15px;
      }
      .navbar-brand {
        font-size: 16px;
      }
      .navbar-brand img {
        height: 35px;
      }
      .btn-nav {
        font-size: 12px;
        padding: 6px 12px;
      }
    }
    @media (max-width: 576px) {
      .stats-grid {
        display: grid !important;
        grid-template-columns: repeat(2, 1fr) !important;
        gap: 10px !important;
      }
      .stat-card {
        flex-direction: column !important;
        align-items: center !important;
        text-align: center !important;
      }
      .stat-icon {
        margin-bottom: 8px;
      }
      .stat-content {
        width: 100%;
      }
      .table-responsive {
        font-size: 12px;
      }
      .table th, .table td {
        padding: 8px 4px;
      }
      .input-group-responsive {
        flex-direction: column;
        gap: 8px;
      }
      .input-group-responsive input,
      .input-group-responsive button {
        width: 100% !important;
        min-width: 0;
        border-radius: 8px !important;
      }
    }
  /* DataTable Styling */
  table.dataTable {
    border-collapse: separate !important;
    border-spacing: 0;
    margin-top: 1rem !important;
    border-radius: 10px;
    overflow: hidden;
    width: 100% !important;
  }
  
  table.dataTable thead th {
    background: linear-gradient(135deg, rgba(67, 97, 238, 0.05), rgba(76, 201, 240, 0.1));
    border-bottom: 2px solid rgba(67, 97, 238, 0.2);
    font-weight: 700;
    padding: 15px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--primary-color);
  }
  
  table.dataTable tbody td {
    padding: 15px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    font-size: 14px;
    vertical-align: middle;
    transition: all var(--transition-speed) ease;
  }
  
  table.dataTable tbody tr:hover td {
    background-color: rgba(67, 97, 238, 0.05);
  }
  
  table.dataTable tbody tr:last-child td {
    border-bottom: none;
  }
  </style>
</head>
<body>
  <!-- Navbar atas dihilangkan untuk tampilan mobile minimalis -->

  <div class="main-container">
    <div class="container">
      <% if (typeof notif !== 'undefined' && notif) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert" id="notif-alert">
          <i class="bi bi-check-circle me-2"></i><%= notif %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% } %>
      
      <script>
        setTimeout(function() {
          var notif = document.getElementById('notif-alert');
          if (notif) notif.classList.remove('show');
        }, 3000);
      </script>

      <div class="row">
        <div class="col-12">

          <!-- BILLING INFORMATION - TOP PRIORITY -->
          <% if (typeof billingData !== 'undefined' && billingData && billingData.customer) { %>
          <div class="form-section" style="order: -1;">
            <h6><i class="bi bi-receipt"></i>Billing Information</h6>
            <div class="row">
              <div class="col-md-6">
                <div class="card border-0 bg-light">
                  <div class="card-body">
                    <h6 class="card-title text-primary">
                      <i class="bi bi-person-circle me-2"></i>Customer Data
                    </h6>
                    <div class="mb-2">
                      <strong>Name:</strong> <%= billingData.customer.name %>
                    </div>
                    <div class="mb-2">
                      <strong>Username:</strong> <%= billingData.customer.username %>
                    </div>
                    <div class="mb-2">
                      <strong>Package:</strong> 
                      <% if (billingData.customer.package_name) { %>
                        <span class="badge bg-info">
                          <%= billingData.customer.package_name %> - Rp <%= parseFloat(billingData.customer.package_price).toLocaleString('en-GB') %>
                        </span>
                      <% } else { %>
                        <span class="text-muted">No package assigned</span>
                      <% } %>
                    </div>
                    <div class="mb-2">
                      <strong>Payment Status:</strong>
                      <% if (billingData.customer.payment_status === 'paid') { %>
                        <span class="badge bg-success">Paid</span>
                      <% } else if (billingData.customer.payment_status === 'unpaid') { %>
                        <span class="badge bg-warning">Unpaid</span>
                      <% } else if (billingData.customer.payment_status === 'overdue') { %>
                        <span class="badge bg-danger">Overdue</span>
                      <% } else { %>
                        <span class="badge bg-secondary">No Invoice</span>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="card border-0 bg-light">
                  <div class="card-body">
                    <h6 class="card-title text-primary">
                      <i class="bi bi-calculator me-2"></i>Billing Summary
                    </h6>
                    <div class="mb-2">
                      <strong>Total Invoices:</strong> <%= billingData.invoices.length %>
                    </div>
                    <div class="mb-2">
                      <strong>Paid Invoices:</strong> 
                      <span class="badge bg-success">
                        <%= billingData.invoices.filter(inv => inv.status === 'paid').length %>
                      </span>
                    </div>
                    <div class="mb-2">
                      <strong>Unpaid Invoices:</strong> 
                      <span class="badge bg-warning">
                        <%= billingData.invoices.filter(inv => inv.status === 'unpaid').length %>
                      </span>
                    </div>
                    <div class="mb-2">
                      <strong>Total Unpaid Amount:</strong> 
                      <span class="text-danger fw-bold">
                        Rp <%= billingData.invoices.filter(inv => inv.status === 'unpaid').reduce((sum, inv) => sum + parseFloat(inv.amount), 0).toLocaleString('en-GB') %>
                      </span>
                    </div>
                    <div class="mt-3">
                      <a href="/customer/billing/dashboard" class="btn btn-primary btn-sm me-2">
                        <i class="bi bi-eye me-1"></i>View Billing Details
                      </a>
                      <% if (billingData.invoices.filter(inv => inv.status === 'unpaid').length > 0) { %>
                        <button class="btn btn-success btn-sm quick-pay-btn" data-bs-toggle="modal" data-bs-target="#quickPayModal">
                          <i class="bi bi-credit-card me-1"></i>Quick Pay
                        </button>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <% if (billingData.invoices && billingData.invoices.length > 0) { %>
          <div class="table-container" style="order: -1;">
            <h6><i class="bi bi-receipt-cutoff"></i>Billing History</h6>
            <div class="table-responsive">
              <table class="table table-hover" id="invoicesTable" style="width:100%">
                <thead>
                  <tr>
                    <th>Invoice No.</th>
                    <th>Amount</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Created Date</th>
                  </tr>
                </thead>
                <tbody>
                  <% billingData.invoices.forEach(function(invoice) { %>
                    <tr>
                      <td>
                        <span class="fw-bold"><%= invoice.invoice_number %></span>
                      </td>
                      <td>
                        <span class="fw-bold text-primary">
                          Rp <%= parseFloat(invoice.amount).toLocaleString('en-GB') %>
                        </span>
                      </td>
                      <td>
                        <% if (new Date(invoice.due_date) < new Date() && invoice.status === 'unpaid') { %>
                          <span class="text-danger fw-bold">
                            <%= new Date(invoice.due_date).toLocaleDateString('en-GB') %>
                          </span>
                        <% } else { %>
                          <%= new Date(invoice.due_date).toLocaleDateString('en-GB') %>
                        <% } %>
                      </td>
                      <td>
                        <% if (invoice.status === 'paid') { %>
                          <span class="badge bg-success">Paid</span>
                        <% } else if (invoice.status === 'unpaid') { %>
                          <% if (new Date(invoice.due_date) < new Date()) { %>
                            <span class="badge bg-danger">Overdue</span>
                          <% } else { %>
                            <span class="badge bg-warning">Unpaid</span>
                          <% } %>
                        <% } %>
                      </td>
                      <td>
                        <%= new Date(invoice.created_at).toLocaleDateString('en-GB') %>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
          <% } %>
          <% } else { %>
          <div class="form-section" style="order: -1;">
            <h6><i class="bi bi-receipt"></i>Billing Information</h6>
            <div class="alert alert-info">
              <i class="bi bi-info-circle me-2"></i>
              Billing data is not yet available. Please contact admin to register your phone number in the billing system.
            </div>
          </div>
          <% } %>

          <!-- GENIEACS DEVICE INFORMATION -->
          <div class="form-section">
            <h6><i class="bi bi-router"></i>Device Information</h6>
            <div class="row">
              <div class="col-12">
                <div class="stats-grid">
                  <div class="stat-card wifi">
                    <div class="stat-icon wifi">
                      <i class="bi bi-circle-fill"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">Status Device</div>
                      <div class="stat-value">
                        <% if (customer.status === 'Online') { %>
                          <span class="badge bg-success stat-badge"><i class="bi bi-check-circle-fill"></i> Online</span>
                        <% } else { %>
                          <span class="badge bg-secondary stat-badge"><i class="bi bi-x-circle-fill"></i> <%= customer.status %></span>
                        <% } %>
                      </div>
                    </div>
                  </div>
                  <div class="stat-card wifi">
                    <div class="stat-icon wifi">
                      <i class="bi bi-wifi"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">SSID Saat Ini</div>
                      <div class="stat-value"><%= customer.ssid %></div>
                    </div>
                  </div>
                  <div class="stat-card cpu">
                    <div class="stat-icon cpu">
                      <i class="bi bi-cpu"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">Software Version</div>
                      <div class="stat-value"><%= customer.softwareVersion %></div>
                    </div>
                  </div>
                  <div class="stat-card clock">
                    <div class="stat-icon clock">
                      <i class="bi bi-clock-history"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">Last Inform</div>
                      <div class="stat-value"><%= customer.lastInform %></div>
                    </div>
                  </div>
                  <div class="stat-card activity">
                    <div class="stat-icon activity">
                      <i class="bi bi-activity"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">RX Power</div>
                      <div class="stat-value"><%= customer.rxPower %></div>
                    </div>
                  </div>
                  <div class="stat-card globe">
                    <div class="stat-icon globe">
                      <i class="bi bi-globe"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">PPPoE IP</div>
                    <div class="stat-value"><%= typeof customer.pppoeIP === 'object' 
                      ? (customer.pppoeIP._value || customer.pppoeIP.address || customer.pppoeIP.ip || JSON.stringify(customer.pppoeIP)) 
                      : customer.pppoeIP %></div>
                    </div>
                  </div>
                  <div class="stat-card person">
                    <div class="stat-icon person">
                      <i class="bi bi-person"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">PPPoE Username</div>
                      <div class="stat-value"><%= customer.pppoeUsername %></div>
                    </div>
                  </div>
                  <div class="stat-card people">
                    <div class="stat-icon people">
                      <i class="bi bi-people"></i>
                    </div>
                    <div class="stat-content">
                      <div class="stat-label">Connected Users</div>
                      <div class="stat-value"><%= customer.totalAssociations %></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- GENIEACS DEVICE SETTINGS -->
          <div class="form-section">
            <h6><i class="bi bi-gear-fill"></i>Device Settings</h6>
            <% if (customer.status !== 'Unknown' && customer.status !== 'Error' && customer.ssid !== '-') { %>
              <div class="row">
                <!-- Change SSID -->
                <div class="col-md-6 mb-3">
                  <div class="card border-0 bg-light h-100">
                    <div class="card-body">
                      <h6 class="card-title text-primary">
                        <i class="bi bi-wifi me-2"></i>Change WiFi Name (SSID)
                      </h6>
                      <div class="input-group input-group-responsive">
                        <input type="text" class="form-control" id="newSsid" placeholder="New WiFi Name" maxlength="32" value="<%= customer && customer.ssid && customer.ssid !== '-' ? customer.ssid : '' %>">
                        <button class="btn btn-action btn-ssid" type="button" id="changeSsidBtn">
                          <i class="bi bi-check-lg me-1"></i>Change SSID
                        </button>
                      </div>
                      <small class="text-muted mt-2 d-block">
                        <i class="bi bi-info-circle me-1"></i>
                        SSID must be 3-32 characters. 5GHz WiFi will automatically be "WiFiName-5G"
                      </small>
                    </div>
                  </div>
                </div>

                <!-- Change Password -->
                <div class="col-md-6 mb-3">
                  <div class="card border-0 bg-light h-100">
                    <div class="card-body">
                      <h6 class="card-title text-primary">
                        <i class="bi bi-shield-lock me-2"></i>Change WiFi Password
                      </h6>
                      <div class="input-group input-group-responsive">
                        <input type="text" class="form-control" id="newPassword" placeholder="New Password" maxlength="63">
                        <button class="btn btn-action btn-password" type="button" id="changePasswordBtn">
                          <i class="bi bi-check-lg me-1"></i>Change Password
                        </button>
                      </div>
                      <small class="text-muted mt-2 d-block">
                        <i class="bi bi-info-circle me-1"></i>
                        Password must be 8-63 characters for security
                      </small>
                    </div>
                  </div>
                </div>

                <!-- Restart Device -->
                <div class="col-12 mb-3">
                  <div class="card border-0 bg-light">
                    <div class="card-body">
                      <h6 class="card-title text-primary">
                        <i class="bi bi-arrow-clockwise me-2"></i>Restart Device
                      </h6>
                      <div class="d-grid">
                        <button class="btn btn-action btn-restart" type="button" id="restartDeviceBtn">
                          <i class="bi bi-arrow-clockwise me-1"></i>Restart Device
                        </button>
                      </div>
                      <small class="text-muted mt-2 d-block">
                        <i class="bi bi-info-circle me-1"></i>
                        Restarting device will temporarily disconnect internet (1-2 minutes)
                      </small>
                    </div>
                  </div>
                </div>
              </div>
            <% } else { %>
              <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Device not detected or not connected. WiFi settings only available when device is online.
              </div>
              <small class="text-muted mt-2 d-block">
                <i class="bi bi-info-circle me-1"></i>
                Please contact admin if your device is not detected in the system
              </small>
            <% } %>
          </div>

          <div class="table-container">
            <h6><i class="bi bi-devices"></i>Connected Devices</h6>
            <% if (connectedUsers && connectedUsers.length > 0) { %>
              <div class="table-responsive">
                <table class="table table-hover" id="connectedDevicesTable" style="width:100%">
                  <thead>
                    <tr>
                      <th>Hostname</th>
                      <th>IP</th>
                      <th>MAC</th>
                      <th>Interface</th>
                      <th>Time</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% connectedUsers.forEach(function(user) { %>
                      <tr>
                        <td><%= user.hostname %></td>
                        <td><%= user.ip %></td>
                        <td><%= user.mac %></td>
                        <td><%= user.iface %></td>
                        <td><%= user.waktu %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } else { %>
              <div class="alert alert-warning mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i>
                No devices are currently connected.
              </div>
            <% } %>
          </div>

          <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>
            If you experience any issues, please contact admin via WhatsApp: 
            <a href="https://wa.me/<%= customer.adminNumberWA || '6281947215703' %>" target="_blank" class="alert-link">
              <i class="bi bi-whatsapp me-1"></i><%= customer.adminNumber || '03036783333' %>
            </a>
          </div>
        </div>
      </div>

      <!-- Modal Pay Cepat -->
      <% if (typeof billingData !== 'undefined' && billingData && billingData.invoices) { %>
      <div class="modal fade" id="quickPayModal" tabindex="-1" aria-labelledby="quickPayModalLabel" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="quickPayModalLabel">Pay Invoice</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <p class="mb-3">Select the invoice you want to pay:</p>
              <div class="list-group">
                <% billingData.invoices.filter(inv => inv.status === 'unpaid').forEach(function(invoice) { %>
                  <label class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    <div class="form-check">
                      <input class="form-check-input me-2" type="radio" name="selectedInvoice" 
                             value="<%= invoice.id %>" 
                             data-invoice-number="<%= invoice.invoice_number %>"
                             data-amount="<%= invoice.amount %>">
                      <span class="fw-bold"><%= invoice.invoice_number %></span><br>
                      <small class="text-muted">Due: <%= new Date(invoice.due_date).toLocaleDateString('en-GB') %></small>
                    </div>
                    <span class="badge bg-primary">Rp <%= parseFloat(invoice.amount).toLocaleString('en-GB') %></span>
                  </label>
                <% }); %>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" class="btn btn-success" id="proceedPayBtn" disabled>
                <i class="bi bi-credit-card me-1"></i>Proceed to Pay
              </button>
            </div>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Restart Confirmation Modal -->
      <div class="modal fade" id="restartModal" tabindex="-1" aria-labelledby="restartModalLabel" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="restartModalLabel">Confirm Device Restart</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-triangle"></i> <strong>Warning!</strong>
              </div>
              <p>Are you sure you want to restart your device?</p>
              <ul class="text-muted small">
                <li>Internet connection will be temporarily interrupted</li>
                <li>The restart process takes approximately 1-2 minutes</li>
                <li>All connected devices will be disconnected</li>
              </ul>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" class="btn btn-danger" id="confirmRestart">
                <i class="bi bi-arrow-clockwise"></i> Yes, Restart
              </button>
            </div>
          </div>
        </div>
      </div>

      <footer class="footer">
        &copy; <%= new Date().getFullYear() %> <%= customer.companyHeader || 'NBB Wifiber' %>
      </footer>

      <!-- DataTables JS -->
      <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
      <script src="/js/customer-mobile.js"></script>
      <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
      <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
      <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
      <script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

      <script>
      $(document).ready(function() {
        // Initialize DataTable for connected devices if table exists
        if ($('#connectedDevicesTable').length) {
          $('#connectedDevicesTable').DataTable({
            responsive: true,
            language: {
              emptyTable: "No data available",
              info: "Showing _START_ to _END_ of _TOTAL_ entries",
              infoEmpty: "Showing 0 to 0 of 0 entries",
              infoFiltered: "(filtered from _MAX_ total entries)",
              lengthMenu: "Show _MENU_ entries",
              loadingRecords: "Loading...",
              processing: "Processing...",
              search: "Search:",
              zeroRecords: "No matching records found",
              paginate: {
                first: "First",
                last: "Last",
                next: "Next",
                previous: "Previous"
              }
            },
            dom: '<"top"f>rt<"bottom"lip><"clear">',
            ordering: true,
            info: true,
            paging: true,
            pageLength: 5,
            lengthMenu: [[5, 10, 25, -1], [5, 10, 25, "All"]],
            columnDefs: [{
              targets: '_all',
              className: 'align-middle'
            }]
          });
        }

        // Initialize DataTable for invoices if table exists
        if ($('#invoicesTable').length) {
          $('#invoicesTable').DataTable({
            responsive: true,
            language: {
              emptyTable: "No data available",
              info: "Showing _START_ to _END_ of _TOTAL_ entries",
              infoEmpty: "Showing 0 to 0 of 0 entries",
              infoFiltered: "(filtered from _MAX_ total entries)",
              lengthMenu: "Show _MENU_ entries",
              loadingRecords: "Loading...",
              processing: "Processing...",
              search: "Search:",
              zeroRecords: "No matching records found",
              paginate: {
                first: "First",
                last: "Last",
                next: "Next",
                previous: "Previous"
              }
            },
            dom: '<"top"f>rt<"bottom"lip><"clear">',
            ordering: true,
            info: true,
            paging: true,
            pageLength: 5,
            lengthMenu: [[5, 10, 25, -1], [5, 10, 25, "All"]],
            columnDefs: [{
              targets: '_all',
              className: 'align-middle'
            }]
          });
        }

        // Add animation to stat cards
        $('.stat-card').each(function(index) {
          $(this).addClass('animate__animated animate__fadeInUp')
                .css('animation-delay', (index * 0.1) + 's');
        });
        
        // Add animation to form sections
        $('.form-section').each(function(index) {
          $(this).addClass('animate__animated animate__fadeInUp')
                .css('animation-delay', ((index + 8) * 0.1) + 's');
        });
        
        // Add animation to table container
        $('.table-container').each(function(index) {
          $(this).addClass('animate__animated animate__fadeInUp')
                 .css('animation-delay', (1.3 + (index * 0.1)) + 's');
        });

        // Modern toast notification function
        function showToast(type, title, message, duration = 5000) {
          const toastId = 'toast-' + Date.now();
          const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';
          const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
          
          const toastHtml = `
            <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;">
              <div class="d-flex">
                <div class="toast-body">
                  <i class="bi ${iconClass} me-2"></i>
                  <strong>${title}</strong><br>
                  <small>${message}</small>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
              </div>
            </div>
          `;
          
          $('body').append(toastHtml);
          const toastElement = document.getElementById(toastId);
          const toast = new bootstrap.Toast(toastElement, { delay: duration });
          toast.show();
          
          // Auto remove after hide
          toastElement.addEventListener('hidden.bs.toast', () => {
            toastElement.remove();
          });
        }

        // Handle Change SSID
        $('#changeSsidBtn').on('click', function(e) {
          e.preventDefault();
          const newSsid = $('#newSsid').val().trim();
          
          if (!newSsid || newSsid.length < 3 || newSsid.length > 32) {
            showToast('error', 'Error', 'SSID must contain 3-32 characters!');
            return;
          }
          
          const $btn = $(this);
          const originalText = $btn.html();
          $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Processing...');
          
          $.ajax({
            url: '/customer/api/change-ssid',
            method: 'POST',
            data: { ssid: newSsid },
            success: function(res) {
              if (res.success) {
                // Immediate feedback for user
                showToast('success', 'SSID Being Processed!', 
                  `WiFi 2.4GHz: ${res.newSSID} is being updated. The process will complete in a few seconds.`);
                $('#newSsid').val('');
                
                // Update SSID in stat card immediately
                $('.stat-card .stat-value').each(function() {
                  if ($(this).text().includes('SSID')) {
                    $(this).text(res.newSSID);
                  }
                });
                
                // Reset button after 2 seconds
                setTimeout(() => {
                  $btn.prop('disabled', false).html(originalText);
                }, 2000);
                
              } else {
                showToast('error', 'Error', res.message || 'Failed to change SSID!');
                $btn.prop('disabled', false).html(originalText);
              }
            },
            error: function(err) {
              const errorMsg = err.responseJSON?.message || 'Failed to change SSID!';
              showToast('error', 'Error', errorMsg);
              $btn.prop('disabled', false).html(originalText);
            }
          });
        });

        // Handle Change Password
        $('#changePasswordBtn').on('click', function(e) {
          e.preventDefault();
          const newPassword = $('#newPassword').val().trim();
          
          if (!newPassword || newPassword.length < 8 || newPassword.length > 63) {
            showToast('error', 'Error', 'Password must contain 8-63 characters!');
            return;
          }
          
          const $btn = $(this);
          const originalText = $btn.html();
          $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Processing...');
          
          $.ajax({
            url: '/customer/api/change-password',
            method: 'POST',
            data: { password: newPassword },
            success: function(res) {
              if (res.success) {
                // Immediate feedback for user
                showToast('success', 'Password Being Processed!', 
                  `WiFi password is being updated. The process will complete in a few seconds.`);
                $('#newPassword').val('');
                
                // Reset button after 2 seconds
                setTimeout(() => {
                  $btn.prop('disabled', false).html(originalText);
                }, 2000);
                
              } else {
                showToast('error', 'Error', res.message || 'Failed to change password!');
                $btn.prop('disabled', false).html(originalText);
              }
            },
            error: function(err) {
              const errorMsg = err.responseJSON?.message || 'Failed to change password!';
              showToast('error', 'Error', errorMsg);
              $btn.prop('disabled', false).html(originalText);
            }
          });
        });

        // Initialize restart modal
        const restartModal = new bootstrap.Modal(document.getElementById('restartModal'));
        
        // Handle button that opens restart modal
        $('#restartDeviceBtn').on('click', function() {
          restartModal.show();
        });
        
        // Handle radio button selection for quick pay
        $('input[name="selectedInvoice"]').on('change', function() {
          $('#proceedPayBtn').prop('disabled', false);
        });

        // Handle proceed to pay button
        $('#proceedPayBtn').on('click', function() {
          const selectedInvoice = $('input[name="selectedInvoice"]:checked');
          if (selectedInvoice.length === 0) {
            showToast('error', 'Error', 'Please select an invoice to pay');
            return;
          }

          const invoiceId = selectedInvoice.val();
          const invoiceNumber = selectedInvoice.data('invoice-number');
          const amount = selectedInvoice.data('amount');

          // Redirect to billing invoice detail page
          window.location.href = `/customer/billing/invoices/${invoiceId}`;
        });

        // Handle confirm restart button in modal
        $('#confirmRestart').on('click', function() {
          const btn = $(this);
          const originalText = btn.html();
          
          // Close modal immediately after confirmation
          restartModal.hide();
          
          // Show notification that process is running
          const notifContainer = $('<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080"></div>');
          const notifToast = $(`
            <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true">
              <div class="toast-header bg-primary text-white">
                <i class="bi bi-arrow-clockwise me-2"></i>
                <strong class="me-auto">Restart Device</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
              </div>
              <div class="toast-body d-flex align-items-center">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Processing restart command...</span>
              </div>
            </div>
          `);
          
          notifContainer.append(notifToast);
          $('body').append(notifContainer);
          
          // Send restart request to server
          $.post('/customer/restart-device', function(response) {
            // Update notification with success status
            notifToast.find('.toast-header')
              .removeClass('bg-primary')
              .addClass('bg-success');
            notifToast.find('.toast-header i')
              .removeClass('bi-arrow-clockwise')
              .addClass('bi-check-circle');
            notifToast.find('.toast-body')
              .html(`<i class="bi bi-check-circle-fill me-2"></i>${response.message}`);
            
            // Remove notification after a few seconds
            setTimeout(function() {
              notifToast.fadeOut('slow', function() {
                notifContainer.remove();
              });
            }, 5000);
          }).fail(function(error) {
            // Update notification with error status
            notifToast.find('.toast-header')
              .removeClass('bg-primary')
              .addClass('bg-danger');
            notifToast.find('.toast-header i')
              .removeClass('bi-arrow-clockwise')
              .addClass('bi-exclamation-triangle');
            notifToast.find('.toast-body')
              .html(`<i class="bi bi-exclamation-triangle-fill me-2"></i>Failed to restart device: ${error.responseJSON ? error.responseJSON.message : 'An error occurred'}`);
            
            // Remove notification after a few seconds
            setTimeout(function() {
              notifToast.fadeOut('slow', function() {
                notifContainer.remove();
              });
            }, 5000);
          });
        });
      });
      
      // Function to refresh logo with new timestamp
      function refreshLogo() {
          const logo = document.getElementById('logoImage');
          if (logo) {
              // Add new timestamp parameter to force image reload
              const timestamp = new Date().getTime();
              const src = logo.src.split('?')[0]; // Remove existing parameters
              logo.src = `${src}?v=${timestamp}`;
          }
      }

      // Refresh logo every 5 seconds
      setInterval(refreshLogo, 5000);

      // Refresh logo when page loads
      document.addEventListener('DOMContentLoaded', function() {
          refreshLogo();
      });
      </script>
        </div>
      </div>
    </div>
  </div>

  <div class="install-banner">
    <button class="btn" data-install-app style="display:none">Install Application</button>
  </div>

  <!-- Bottom nav (mobile) 5 menu: Billing, Reports, Home, Invoice, Profile -->
  <nav class="bottom-nav d-md-none">
    <a class="nav-item" href="/customer/billing/dashboard" title="Billing">
      <i class="bi bi-speedometer2"></i>
      <span>Billing</span>
    </a>
    <a class="nav-item" href="/customer/trouble/report" title="Reports">
      <i class="bi bi-exclamation-triangle"></i>
      <span>Reports</span>
    </a>
    <a class="nav-item home-button" href="/customer/dashboard" title="Home">
      <i class="bi bi-house"></i>
      <span>Home</span>
    </a>
    <a class="nav-item" href="/customer/billing/invoices" title="Invoice">
      <i class="bi bi-receipt"></i>
      <span>Invoice</span>
    </a>
    <a class="nav-item" href="/customer/billing/profile" title="Profile">
      <i class="bi bi-person"></i>
      <span>Profile</span>
    </a>
  </nav>
</body>
</html>
