<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Voucher Success - <%= company_header %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
    <style>
        .voucher-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .voucher-code {
            font-family: 'Courier New', monospace;
            font-size: 1.5rem;
            font-weight: bold;
            letter-spacing: 2px;
            background: rgba(255,255,255,0.2);
            padding: 15px;
            border-radius: 10px;
            margin: 10px 0;
        }
        .qr-container {
            background: white;
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            margin: 20px 0;
        }
        .instruction-card {
            background: #f8f9fa;
            border-left: 4px solid #28a745;
            padding: 20px;
            margin: 20px 0;
        }
        .print-btn {
            background: #28a745;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            color: white;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        .print-btn:hover {
            background: #218838;
            transform: translateY(-2px);
        }
        .whatsapp-btn {
            background: #25d366;
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            color: white;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        .whatsapp-btn:hover {
            background: #1da851;
            transform: translateY(-2px);
        }
        .success-animation {
            animation: bounceIn 0.8s ease-out;
        }
        @keyframes bounceIn {
            0% { transform: scale(0.3); opacity: 0; }
            50% { transform: scale(1.05); }
            70% { transform: scale(0.9); }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>
</head>
<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!-- Success Header -->
                <div class="text-center mb-4 success-animation">
                    <div class="display-1 text-success mb-3">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <h1 class="text-success fw-bold">Payment Successful!</h1>
                    <p class="lead text-muted">Your WiFi voucher has been successfully created</p>
                </div>

                <!-- Voucher Details -->
                <div class="voucher-card p-4 mb-4 success-animation">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h3 class="mb-3">
                                <i class="bi bi-wifi me-2"></i>
                                <%= voucherData.packageName %>
                            </h3>
                            <div class="row">
                                <div class="col-6">
                                    <small class="text-white-50">Duration</small>
                                    <div class="fw-bold"><%= voucherData.duration %></div>
                                </div>
                                <div class="col-6">
                                    <small class="text-white-50">Price</small>
                                    <div class="fw-bold">Rs <%= voucherData.price.toLocaleString('en-PK') %></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="qr-container">
                                <div id="qrcode"></div>
                                <small class="text-muted mt-2 d-block">Scan for WiFi access</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Voucher Codes -->
                <div class="card mb-4 success-animation">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-key me-2"></i>
                            Voucher Code You
                        </h5>
                    </div>
                    <div class="card-body">
                        <% if (voucherData.vouchers && voucherData.vouchers.length > 0) { %>
                            <% voucherData.vouchers.forEach((voucher, index) => { %>
                                <div class="voucher-code text-center mb-3">
                                    <div class="text-muted small">Voucher <%= index + 1 %></div>
                                    <div class="h4 mb-0"><%= voucher.username %></div>
                                    <div class="text-muted small">Password: <%= voucher.password %></div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle me-2"></i>
                                Voucher code is being processed, please refresh this page
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Instructions -->
                <div class="instruction-card success-animation">
                    <h5 class="text-success mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        How to Use Voucher
                    </h5>
                    <ol class="mb-0">
                        <li>Connect your device to WiFi network <strong><%= voucherData.wifiName || 'Hotspot' %></strong></li>
                        <li>Open browser and enter address: <code><%= voucherData.hotspotUrl || 'http://192.168.1.1' %></code></li>
                        <li>Enter the voucher code shown above</li>
                        <li>Click "Login" and enjoy internet access</li>
                    </ol>
                </div>

                <!-- Action Buttons -->
                <div class="text-center mb-4 success-animation">
                    <button class="btn print-btn me-3" onclick="printVoucher()">
                        <i class="bi bi-printer me-2"></i>Print Voucher
                    </button>
                    <button class="btn whatsapp-btn me-3" onclick="sendToWhatsApp()">
                        <i class="bi bi-whatsapp me-2"></i>Send to WhatsApp
                    </button>
                    <button class="btn btn-outline-primary" onclick="refreshVoucher()">
                        <i class="bi bi-arrow-clockwise me-2"></i>Refresh
                    </button>
                </div>

                <!-- Additional Info -->
                <div class="card success-animation">
                    <div class="card-body">
                        <h6 class="text-muted mb-3">
                            <i class="bi bi-shield-check me-2"></i>
                            Important Information
                        </h6>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="bi bi-check-circle text-success me-2"></i>
                                Voucher is valid for <strong><%= voucherData.duration %></strong>
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle text-success me-2"></i>
                                Save this page for future reference
                            </li>
                            <li class="mb-0">
                                <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                                If you have any issues, contact admin: <strong><%= settings.contact_phone || settings['admins.0'] || 'Not available' %></strong>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Footer -->
                    <p class="text-muted">
                        <i class="bi bi-clock me-2"></i>
                        Created on: <%= new Date().toLocaleString('en-GB') %>
                    </p>
                    <a href="/voucher" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Voucher Page
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Generate QR Code
        function generateQRCode() {
            const qrContainer = document.getElementById('qrcode');
            if (qrContainer && window.QRCode) {
                // Generate QR code with simple data
                const qrData = 'Voucher WiFi - ' + window.location.href;
                QRCode.toCanvas(qrContainer, qrData, {
                    width: 200,
                    height: 200,
                    color: {
                        dark: '#000000',
                        light: '#FFFFFF'
                    }
                }, function (error) {
                    if (error) console.error('QR Code generation error:', error);
                });
            }
        }

        // Print voucher
        function printVoucher() {
            window.print();
        }

        // Send to WhatsApp - Server data only
        function sendToWhatsApp() {
            const phone = '<%- voucherData.customerPhone %>';
            if (phone && phone !== 'undefined' && phone !== '') {
                // Use data from server-side variables
                const baseUrl = '<%= settings.server_host || "localhost" %>';
                const port = '<%= settings.server_port || "3003" %>';
                const protocol = (baseUrl.includes('localhost') || baseUrl.match(/^192\.168\.|^10\.|^172\.(1[6-9]|2[0-9]|3[0-1])\./)) ? 'http' : 'https';
                const successUrl = `${protocol}://${baseUrl}:${port}/voucher/success/<%- purchase.id %>`;

                const message = [
                    'Hello! WiFi voucher successfully purchased.',
                    '',
                    'Complete details: ' + successUrl,
                    '',
                    'Thank you for using our service!'
                ].join('\n');

                window.open('https://wa.me/' + phone + '?text=' + encodeURIComponent(message), '_blank');
            } else {
                alert('WhatsApp Number unavailable');
            }
        }
        // Refresh voucher data
        function refreshVoucher() {
            window.location.reload();
        }

        // Auto-refresh if no vouchers
        function checkVoucherStatus() {
            const voucherCount = document.querySelectorAll('.voucher-code').length;
            if (voucherCount === 0) {
                setTimeout(() => {
                    window.location.reload();
                }, 5000); // Refresh every 5 seconds if no vouchers
            }
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            generateQRCode();
            checkVoucherStatus();
        });
    </script>
</body>
</html>