<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - <%= appSettings.companyHeader %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="manifest" href="/manifest.webmanifest">
    <meta name="theme-color" content="#0B1437">
    <link rel="apple-touch-icon" href="/img/icons/icon-192.png">
    <link rel="stylesheet" href="/css/pwa.css">
    <link rel="stylesheet" href="/css/customer-responsive.css">
    <script defer src="/js/pwa-install.js"></script>
    <style>
        body { background: #f8f9fa; }
        .navbar-brand img { max-height: 40px; }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .form-control { border-radius: 10px; }
        .btn { border-radius: 10px; }
    </style>
 </head>
 <body>
    <!-- Navbar atas dihilangkan untuk tampilan mobile minimalis -->

    <div class="container mt-4">
        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-person-circle"></i> My Profile</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input class="form-control" value="<%= customer ? customer.name : '-' %>" disabled>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Username</label>
                                <input class="form-control" value="<%= customer ? customer.username : '-' %>" disabled>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone</label>
                                <input class="form-control" value="<%= customer ? customer.phone : '-' %>" disabled>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Package</label>
                                <input class="form-control" value="<%= customer && customer.package_name ? customer.package_name : '-' %>" disabled>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="row g-3">
                            <div class="col-12">
                                <h6 class="mb-2"><i class="bi bi-shield-lock"></i> Change Login Password</h6>
                                <div id="passwordAlert" class="alert" style="display:none;"></div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Current Password</label>
                                <input type="password" class="form-control" id="current_password" autocomplete="current-password">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">New Password</label>
                                <input type="password" class="form-control" id="new_password" autocomplete="new-password">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Confirm New Password</label>
                                <input type="password" class="form-control" id="confirm_password" autocomplete="new-password">
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="d-grid w-100">
                                    <button class="btn btn-primary" id="btnChangePortalPassword" type="button">
                                        <i class="bi bi-key"></i> Save Password
                                    </button>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Logout Button -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="d-grid">
                                    <a href="/customer/logout" class="btn btn-danger" onclick="return confirm('Are you sure you want to logout?')">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-info-circle"></i> Help</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">Contact admin for profile data changes.</p>
                        <a href="https://wa.me/62<%= (appSettings.contact_whatsapp || '03036783333').replace(/^0/, '') %>" class="btn btn-success w-100" target="_blank">
                            <i class="bi bi-whatsapp"></i> WhatsApp Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-light mt-5 py-4">
        <div class="container text-center">
            <p class="mb-0 text-muted"><%= appSettings.footerInfo %></p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/customer-mobile.js"></script>
    <script>
        (function () {
            const btn = document.getElementById('btnChangePortalPassword');
            if (!btn) return;

            function showAlert(type, message) {
                const el = document.getElementById('passwordAlert');
                if (!el) return;
                el.className = 'alert alert-' + type;
                el.textContent = message;
                el.style.display = 'block';
            }

            btn.addEventListener('click', async function () {
                const currentPassword = document.getElementById('current_password')?.value || '';
                const newPassword = document.getElementById('new_password')?.value || '';
                const confirmPassword = document.getElementById('confirm_password')?.value || '';

                btn.disabled = true;
                try {
                    const res = await fetch('/customer/billing/profile/password', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: new URLSearchParams({
                            current_password: currentPassword,
                            new_password: newPassword,
                            confirm_password: confirmPassword
                        })
                    });
                    const data = await res.json().catch(() => ({}));
                    if (!res.ok || !data.success) {
                        showAlert('danger', data.message || 'Failed to change password');
                        return;
                    }
                    document.getElementById('current_password').value = '';
                    document.getElementById('new_password').value = '';
                    document.getElementById('confirm_password').value = '';
                    showAlert('success', data.message || 'Password changed successfully');
                } catch (e) {
                    showAlert('danger', 'An error occurred while changing password');
                } finally {
                    btn.disabled = false;
                }
            });
        })();
    </script>

    <!-- Bottom nav (mobile) 5 menu -->
    <nav class="bottom-nav d-md-none">
        <a class="nav-item" href="/customer/billing/dashboard">
            <i class="bi bi-speedometer2"></i>
            <span>Billing</span>
        </a>
        <a class="nav-item" href="/customer/trouble/report">
            <i class="bi bi-exclamation-triangle"></i>
            <span>Laporan</span>
        </a>
        <a class="nav-item home-button" href="/customer/dashboard">
            <i class="bi bi-house"></i>
            <span>Home</span>
        </a>
        <a class="nav-item" href="/customer/billing/invoices">
            <i class="bi bi-receipt"></i>
            <span>Invoice</span>
        </a>
        <a class="nav-item" href="/customer/billing/profile">
            <i class="bi bi-person"></i>
            <span>Profile</span>
        </a>
    </nav>
 </body>
 </html>


