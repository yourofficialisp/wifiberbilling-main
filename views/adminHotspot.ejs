    // Function untuk cleanup expired vouchers
    window.cleanupExpiredVouchers = function() {
        const statusDiv = document.getElementById('cleanupStatus');
        const button = event.target;

        // Show loading
        statusDiv.style.display = 'block';
        statusDiv.innerHTML = '<small class="text-muted"><i class="bi bi-hourglass me-1"></i>Processing cleanup...</small>';
        button.disabled = true;
        button.innerHTML = '<i class="bi bi-hourglass me-1"></i>Processing...';

        // Call cleanup API
        fetch('/voucher/cleanup-expired', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({})
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                statusDiv.innerHTML = `<small class="text-success"><i class="bi bi-check-circle me-1"></i>${data.message}</small>`;
                if (data.details) {
                    statusDiv.innerHTML += `<br><small class="text-muted">Database: ${data.details.database_deleted}, Mikrotik: ${data.details.mikrotik_deleted}</small>`;
                }

                // Reset button after 3 seconds
                setTimeout(() => {
                    button.disabled = false;
                    button.innerHTML = '<i class="bi bi-trash me-1"></i>Cleanup Now';
                    statusDiv.style.display = 'none';
                }, 3000);

                // Show success toast
                showToast('Expired voucher cleanup successful!', 'success');

            } else {
                statusDiv.innerHTML = `<small class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>${data.message}</small>`;
                button.disabled = false;
                button.innerHTML = '<i class="bi bi-trash me-1"></i>Cleanup Now';

                // Show error toast
                showToast('Failed to cleanup expired vouchers', 'error');
            }
        })
        .catch(error => {
            console.error('Cleanup error:', error);
            statusDiv.innerHTML = '<small class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i>An error occurred during cleanup</small>';
            button.disabled = false;
            button.innerHTML = '<i class="bi bi-trash me-1"></i>Cleanup Now';

            showToast('Error during expired voucher cleanup', 'error');
        });
    };

