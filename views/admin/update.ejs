<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - <%= settings.company_header || 'GEMBOK' %></title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        .terminal-output {
            background-color: #1e1e1e;
            color: #d4d4d4;
            font-family: 'Consolas', 'Monaco', monospace;
            padding: 15px;
            border-radius: 5px;
            height: 300px;
            overflow-y: auto;
            white-space: pre-wrap;
            font-size: 0.9rem;
            margin-top: 15px;
            border: 1px solid #333;
        }
        .status-badge {
            font-size: 0.9em;
            padding: 5px 10px;
        }
    </style>
</head>
<body>
    <div class="row m-0">
        <!-- Sidebar -->
        <%- include('../partials/admin-sidebar') %>

        <!-- Main Content -->
        <main class="col-md-10 ms-sm-auto px-md-4 py-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">System Update</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <div class="btn-group me-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="checkUpdate()">
                            <i class="bi bi-arrow-clockwise"></i> Check Update
                        </button>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Version Information</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="fw-bold">Current Version (Commit Hash):</label>
                                <div class="font-monospace"><%= currentVersion %></div>
                            </div>
                            <div class="mb-3">
                                <label class="fw-bold">Last Commit Message:</label>
                                <div><%= latestCommitMsg %></div>
                            </div>
                            <div class="mb-3">
                                <label class="fw-bold">Last Update Date:</label>
                                <div><%= lastUpdate %></div>
                            </div>
                        </div>
                    </div>

                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Status & Actions</h5>
                        </div>
                        <div class="card-body text-center">
                            <div id="updateStatusSection" class="mb-3">
                                <div class="alert alert-secondary">
                                    Please click "Check Update" to see if a new version is available.
                                </div>
                            </div>
                            
                            <button id="btnUpdate" class="btn btn-primary d-none" onclick="performUpdate()">
                                <i class="bi bi-cloud-arrow-down"></i> Update Now
                            </button>
                            
                            <div class="mt-3 text-muted small">
                                <i class="bi bi-info-circle"></i> Update will not change your <code>settings.json</code> file.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Process Log</h5>
                        </div>
                        <div class="card-body p-0">
                            <div id="terminalOutput" class="terminal-output m-0 border-0 h-100" style="border-radius: 0 0 5px 5px; max-height: 400px;">
Ready waiting for commands...
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const terminal = document.getElementById('terminalOutput');
        const updateStatusSection = document.getElementById('updateStatusSection');
        const btnUpdate = document.getElementById('btnUpdate');

        function log(message, type = 'info') {
            const timestamp = new Date().toLocaleTimeString();
            let color = '#d4d4d4';
            if (type === 'error') color = '#ff6b6b';
            if (type === 'success') color = '#4ecc4e';
            if (type === 'warning') color = '#f1c40f';

            terminal.innerHTML += `<div style="color: ${color}">[${timestamp}] ${message}</div>`;
            terminal.scrollTop = terminal.scrollHeight;
        }

        async function checkUpdate() {
            log('Checking update from repository...', 'info');
            btnUpdate.classList.add('d-none');
            
            try {
                const response = await fetch('/admin/update/check', { method: 'POST' });
                const result = await response.json();
                
                if (result.success) {
                    if (result.updateAvailable) {
                        log('Update available!', 'success');
                        log('New changes:\n' + result.log, 'info');
                        updateStatusSection.innerHTML = `
                            <div class="alert alert-success">
                                <h6 class="alert-heading"><i class="bi bi-check-circle"></i> Update Available!</h6>
                                <p class="mb-0">New version found in repository. Click button below to update.</p>
                            </div>
                        `;
                        btnUpdate.classList.remove('d-none');
                    } else {
                        log('Your system is already up to date.', 'success');
                        updateStatusSection.innerHTML = `
                            <div class="alert alert-info">
                                <i class="bi bi-check-circle"></i> System is up-to-date.
                            </div>
                        `;
                    }
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                log('Failed to check update: ' + error.message, 'error');
                updateStatusSection.innerHTML = `
                    <div class="alert alert-danger">
                        Error: ${error.message}
                    </div>
                `;
            }
        }

        async function performUpdate() {
            if (!confirm('Are you sure you want to perform system update? Application may restart.')) return;

            log('Starting update process...', 'info');
            btnUpdate.disabled = true;
            btnUpdate.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Updating...';
            
            try {
                const response = await fetch('/admin/update/perform', { method: 'POST' });
                const result = await response.json();
                
                if (result.success) {
                    log('Update repository successful.', 'success');
                    if (result.pullOutput) log(result.pullOutput);
                    
                    log('Update dependencies (npm install)...', 'info');
                    if (result.npmOutput) log(result.npmOutput);
                    
                    log('Update database (migrations)...', 'info');
                    if (result.migrateOutput) log(result.migrateOutput);
                    
                    if (result.settingsRestored) {
                        log('settings.json configuration restored from backup.', 'warning');
                    }
                    
                    log('Update complete! Please restart application server if needed.', 'success');
                    alert('Update Successful! Refresh this page.');
                    location.reload();
                } else {
                    throw new Error(result.message);
                }
            } catch (error) {
                log('Update FAILED: ' + error.message, 'error');
                alert('Update Failed. Check log.');
            } finally {
                btnUpdate.disabled = false;
                btnUpdate.innerHTML = '<i class="bi bi-cloud-arrow-down"></i> Update Now';
            }
        }
    </script>
</body>
</html>
