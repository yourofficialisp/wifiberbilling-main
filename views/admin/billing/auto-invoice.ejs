<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto Invoice Settings - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/mobile-sidebar.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                    <h3 class="mb-4">Invoice</h3>

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-4">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'invoices' ? 'active' : '' %>"
                                href="/admin/billing/invoices">
                                <i class="bi bi-receipt"></i> Create Invoice
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'auto-invoice' ? 'active' : '' %>"
                                href="/admin/billing/auto-invoice">
                                <i class="bi bi-calendar-check"></i> Auto Invoice
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'invoices-by-type' ? 'active' : '' %>"
                                href="/admin/billing/invoices-by-type">
                                <i class="bi bi-list-ul"></i> Invoice by Type
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'invoice-list' ? 'active' : '' %>"
                                href="/admin/billing/invoice-list">
                                <i class="bi bi-receipt"></i> All Invoices
                            </a>
                        </li>
                    </ul>

                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">
                            <i class="bx bx-calendar-check"></i> Auto Invoice
                        </h1>
                    </div>
                    <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                        <i class="bx bx-info-circle fs-3 me-2"></i>
                        <div>
                            Auto-invoice system active:
                            <ul class="mb-0">
                                <li>Automatic monthly generation every 1st of the month.</li>
                                <li>Invoice due date follows customer's <em>billing_day</em>.</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Status Card -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-info-circle"></i> Auto Invoice System Status
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="bx bx-calendar text-primary" style="font-size: 2rem;"></i>
                                        </div>
                                        <h6>Running Schedule</h6>
                                        <p class="text-muted">Every 1st of the month</p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="bx bx-user-check text-success" style="font-size: 2rem;"></i>
                                        </div>
                                        <h6>Active Customers</h6>
                                        <p class="text-muted">
                                            <%= activeCustomersCount %> customers
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="bx bx-receipt text-info" style="font-size: 2rem;"></i>
                                        </div>
                                        <h6>This Month's Invoice</h6>
                                        <p class="text-muted">
                                            <%= thisMonthInvoicesCount %> invoice
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="mb-2">
                                            <i class="bx bx-time text-warning" style="font-size: 2rem;"></i>
                                        </div>
                                        <h6>Next Run</h6>
                                        <p class="text-muted">
                                            <%= nextRunDate %>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-cog"></i> Manual Actions
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <button type="button" class="btn btn-primary btn-lg w-100 mb-3"
                                        id="generateInvoicesBtn">
                                        <i class="bx bx-calendar-plus"></i> Generate This Month's Invoice
                                    </button>
                                    <p class="text-muted small">Create invoices for all active customers who don't have an invoice this month</p>
                                </div>
                                <div class="col-md-6">
                                    <button type="button" class="btn btn-outline-info btn-lg w-100 mb-3"
                                        id="previewInvoicesBtn">
                                        <i class="bx bx-show"></i> Preview Invoices to be Created
                                    </button>
                                    <p class="text-muted small">View list of customers who will have invoices created</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Preview Section -->
                    <div class="card" id="previewSection" style="display: none;">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-list-ul"></i> Preview of Invoices to be Created
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-centered table-nowrap table-hover mb-0" id="previewTable">
                                    <thead>
                                        <tr>
                                            <th>Username</th>
                                            <th>Name</th>
                                            <th>Package</th>
                                            <th>Price</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody id="previewTableBody">
                                        <!-- Preview data will be loaded here -->
                                    </tbody>
                                </table>
                            </div>
                            <div class="mt-3">
                                <button type="button" class="btn btn-success" id="confirmGenerateBtn">
                                    <i class="bx bx-check"></i> Confirm Generate Invoice
                                </button>
                                <button type="button" class="btn btn-secondary" id="cancelPreviewBtn">
                                    <i class="bx bx-x"></i> Cancel
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Settings Section removed: now following per-customer billing_day and daily scheduler -->
                </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Generate Invoices
        document.getElementById('generateInvoicesBtn').addEventListener('click', function () {
            if (confirm('Are you sure you want to generate invoices for all active customers?')) {
                this.disabled = true;
                this.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Generating...';

                fetch('/admin/billing/auto-invoice/generate', {
                    method: 'POST'
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showAlert('success', `Successfully generated ${data.count} invoices`);
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            showAlert('danger', data.message || 'Failed to generate invoices');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showAlert('danger', 'An error occurred');
                    })
                    .finally(() => {
                        this.disabled = false;
                        this.innerHTML = '<i class="bx bx-calendar-plus"></i> Generate This Month\'s Invoice';
                    });
            }
        });

        // Preview Invoices
        document.getElementById('previewInvoicesBtn').addEventListener('click', function () {
            this.disabled = true;
            this.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Loading...';

            fetch('/admin/billing/auto-invoice/preview')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        displayPreview(data.customers);
                        document.getElementById('previewSection').style.display = 'block';
                    } else {
                        showAlert('danger', data.message || 'Failed to load preview');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showAlert('danger', 'An error occurred');
                })
                .finally(() => {
                    this.disabled = false;
                    this.innerHTML = '<i class="bx bx-show"></i> Preview Invoices to be Created';
                });
        });

        // Display Preview
        function displayPreview(customers) {
            const tbody = document.getElementById('previewTableBody');
            tbody.innerHTML = '';

            if (customers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">No customers need invoices created</td></tr>';
                return;
            }

            customers.forEach(customer => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${customer.username}</td>
                    <td>${customer.name}</td>
                    <td>${customer.package_name || '-'}</td>
                    <td>Rs ${Math.round(parseFloat(customer.package_price || 0)).toLocaleString('en-PK')}</td>
                    <td><span class="badge bg-success">Active</span></td>
                `;
                tbody.appendChild(row);
            });
        }

        // Confirm Generate
        document.getElementById('confirmGenerateBtn').addEventListener('click', function () {
            document.getElementById('generateInvoicesBtn').click();
        });

        // Cancel Preview
        document.getElementById('cancelPreviewBtn').addEventListener('click', function () {
            document.getElementById('previewSection').style.display = 'none';
        });

        // Settings form removed

        function showAlert(type, message) {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            document.querySelector('.main-content').insertAdjacentHTML('afterbegin', alertHtml);
        }
    </script>
    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'settings' }) %>
</body>

</html>