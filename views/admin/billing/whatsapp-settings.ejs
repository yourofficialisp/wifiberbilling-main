<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Settings - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/mobile-sidebar.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        .status-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
            border-left: 5px solid #667eea;
        }

        .template-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
            border: 1px solid #e9ecef;
        }

        .template-header {
            display: flex;
            justify-content: between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f8f9fa;
        }

        .template-title {
            font-weight: bold;
            color: #2c3e50;
            margin: 0;
        }

        .template-description {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            border: 2px solid #e9ecef;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

        .btn {
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-success {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        }

        .btn-warning {
            background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
        }

        .btn-danger {
            background: linear-gradient(135deg, #dc3545 0%, #e83e8c 100%);
        }

        .alert {
            border-radius: 10px;
            border: none;
        }

        .form-check-input:checked {
            background-color: #28a745;
            border-color: #28a745;
        }

        .form-check-input:not(:checked) {
            background-color: #dc3545;
            border-color: #dc3545;
        }

        .template-disabled {
            opacity: 0.6;
            background-color: #f8f9fa !important;
        }

        .template-enabled {
            opacity: 1;
            background-color: #fff !important;
        }

        .variable-item {
            display: inline-block;
            background: #e9ecef;
            padding: 2px 8px;
            margin: 2px;
            border-radius: 4px;
            font-size: 0.8rem;
            color: #495057;
        }

        .variable-list {
            margin-bottom: 1rem;
            padding: 0.5rem;
            background: #f8f9fa;
            border-radius: 5px;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Include Billing Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                    <h3 class="mb-4">Settings</h3>

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-4">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'payment-settings' ? 'active' : '' %>"
                                href="/admin/billing/payment-settings">
                                <i class="bi bi-cog"></i> Payment Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'whatsapp-settings' ? 'active' : '' %>"
                                href="/admin/billing/whatsapp-settings">
                                <i class="bi bi-chat-dots"></i> WhatsApp Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'service-suspension' ? 'active' : '' %>"
                                href="/admin/billing/service-suspension">
                                <i class="bi bi-pause-circle"></i> ISOLIR Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'mapping-new' ? 'active' : '' %>"
                                href="/admin/billing/mapping-new">
                                <i class="bi bi-map"></i> Network Mapping
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'genieacs' ? 'active' : '' %>"
                                href="/admin/genieacs">
                                <i class="bi bi-wifi"></i> GenieACS
                            </a>
                        </li>
                    </ul>

                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">
                            <i class="bx bx-whatsapp"></i> WhatsApp Settings
                        </h1>
                    </div>

                    <!-- Status Cards -->
                    <div class="row">
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-whatsapp text-success"></i> WhatsApp Status</h5>
                                <p class="mb-0" id="whatsappStatus">Checking...</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-people text-primary"></i> Active Customers</h5>
                                <p class="mb-0" id="activeCustomers">Loading...</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-receipt text-warning"></i> Pending Invoices</h5>
                                <p class="mb-0" id="pendingInvoices">Loading...</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-calendar-check text-info"></i> Next Reminder</h5>
                                <p class="mb-0" id="nextReminder">Loading...</p>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp Provider Selection Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                        <i class="bi bi-toggle-on"></i> WhatsApp Provider
                                    </h4>
                                </div>

                                <div class="template-description">
                                    Choose WhatsApp provider to use for sending messages. Baileys
                                    uses WhatsApp Web (free), Meta API uses official Facebook API
                                    (paid).
                                    <br><br>
                                    <strong class="text-danger">⚠️ Meta API for Broadcast Only:</strong>
                                    <ul class="mb-0">
                                        <li>Meta API only for <strong>broadcast invoices & info</strong> (outbound)
                                        </li>
                                        <li>Does not support command handling (REG, STATUS, MENU, etc.)</li>
                                        <li>Use Baileys or Dual Mode for full features</li>
                                    </ul>
                                </div>

                                <form id="providerForm">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="whatsappProvider" class="form-label">
                                                    <i class="bi bi-whatsapp"></i> Select Provider
                                                </label>
                                                <select class="form-select" id="whatsappProvider"
                                                    name="whatsapp_provider">
                                                    <option value="baileys" selected>Baileys (WhatsApp Web - Free)
                                                    </option>
                                                    <option value="meta_api">Meta API (Official - Paid)</option>
                                                </select>
                                                <div class="form-text mt-2">
                                                    <small>
                                                        <strong>Baileys:</strong> Free, uses WhatsApp Web,
                                                        easily blocked<br>
                                                        <strong>Meta API:</strong> Paid, stable, requires API Key
                                                        from Meta
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">
                                                    <i class="bi bi-info-circle"></i> Status Provider
                                                </label>
                                                <div class="alert alert-info" id="providerStatus">
                                                    <i class="bi bi-check-circle"></i> Active Provider: Baileys
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Dual Mode Option -->
                                    <div class="row mt-3">
                                        <div class="col-12">
                                            <div class="form-check form-switch mb-2">
                                                <input class="form-check-input" type="checkbox" id="dualModeEnabled"
                                                    name="whatsapp_dual_mode">
                                                <label class="form-check-label" for="dualModeEnabled">
                                                    <strong>Enable Dual Mode (Baileys + Meta API)</strong>
                                                </label>
                                            </div>
                                            <div class="alert alert-warning" id="dualModeInfo" style="display: none;">
                                                <i class="bi bi-info-circle"></i>
                                                <strong>Dual Mode Active:</strong><br>
                                                <small>
                                                    • Baileys: Command handling (REG, STATUS, MENU)<br>
                                                    • Meta API: Stable mass broadcast<br>
                                                </small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Meta API Configuration (Hidden by default) -->
                                    <div id="metaApiConfig" style="display: none;">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="metaApiKey" class="form-label">
                                                        <i class="bi bi-key"></i> Meta API Key
                                                    </label>
                                                    <input type="password" class="form-control" id="metaApiKey"
                                                        name="whatsapp_meta_api_key"
                                                        placeholder="Enter API Key from Meta">
                                                    <div class="form-text">Get from Meta for Developers</div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="phoneNumberId" class="form-label">
                                                        <i class="bi bi-phone"></i> Phone Number ID
                                                    </label>
                                                    <input type="text" class="form-control" id="phoneNumberId"
                                                        name="whatsapp_phone_number_id"
                                                        placeholder="Enter Phone Number ID">
                                                    <div class="form-text">ID from WhatsApp Business Account</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="webhookUrl" class="form-label">
                                                        <i class="bi bi-link"></i> Webhook URL
                                                    </label>
                                                    <input type="url" class="form-control" id="webhookUrl"
                                                        name="whatsapp_webhook_url"
                                                        placeholder="https://yourdomain.com/webhook/whatsapp">
                                                    <div class="form-text">URL to receive incoming messages</div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="verifyToken" class="form-label">
                                                        <i class="bi bi-shield-lock"></i> Verify Token
                                                    </label>
                                                    <input type="text" class="form-control" id="verifyToken"
                                                        name="whatsapp_verify_token"
                                                        placeholder="Webhook verification token">
                                                    <div class="form-text">Token for webhook verification</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-save"></i> Save Provider Settings
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp Groups Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                        <i class="bi bi-people-fill"></i> WhatsApp Groups
                                    </h4>
                                </div>

                                <div class="template-description">
                                    Select WhatsApp groups to receive broadcast notifications (e.g: technician group, admin group, etc.).
                                </div>

                                <form id="waGroupsForm">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="mb-3">
                                                <label class="form-label">
                                                    <i class="bi bi-toggle-on"></i> Enable WhatsApp Groups
                                                </label>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="waGroupsEnabled"
                                                        name="whatsapp_groups_enabled">
                                                    <label class="form-check-label" for="waGroupsEnabled">
                                                        <strong>Enable broadcast to WhatsApp Groups</strong>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div id="waGroupsConfig" style="display: none;">
                                        <div class="alert alert-info">
                                            <i class="bi bi-info-circle"></i>
                                            <strong>Info:</strong> Select groups that will receive broadcast notifications. Make sure WhatsApp is connected to see group list.
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <button type="button" class="btn btn-primary btn-sm"
                                                        onclick="loadWhatsAppGroups()">
                                                        <i class="bi bi-sync"></i> Refresh Group List
                                                    </button>
                                                    <span id="groupsLoading" class="ms-2" style="display: none;">
                                                        <i class="bi bi-spinner-border spin"></i> Loading...
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-list-check"></i> Select Technician Groups
                                                    </label>
                                                    <div id="groupsList" class="border rounded p-3"
                                                        style="max-height: 300px; overflow-y: auto;">
                                                        <div class="text-muted">
                                                            <small>Click "Refresh Group List" to see WhatsApp group list</small>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-check2-square"></i> Selected Groups
                                                    </label>
                                                    <div id="selectedGroups" class="border rounded p-2"
                                                        style="min-height: 50px;">
                                                        <span class="text-muted">No groups selected yet</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-save"></i> Save Group Settings
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Rate Limiting Settings Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                                <label for="delayBetweenBatches" class="form-label">
                                                    <i class="bi bi-clock"></i> Delay Between Batches (seconds)
                                                </label>
                                                <input type="number" class="form-control" id="delayBetweenBatches"
                                                    min="1" max="300" value="30"
                                                    placeholder="Delay time between batch deliveries">
                                                <div class="form-text">Recommendation: 30-60 seconds for security</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="delayBetweenMessages" class="form-label">
                                                    <i class="bi bi-hourglass-split"></i> Delay Between Messages (seconds)
                                                </label>
                                                <input type="number" class="form-control" id="delayBetweenMessages"
                                                    min="0" max="10" value="2"
                                                    placeholder="Delay time between messages in batch">
                                                <div class="form-text">Recommendation: 1-3 seconds for stability</div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="maxRetries" class="form-label">
                                                    <i class="bi bi-arrow-repeat"></i> Max Retry
                                                </label>
                                                <input type="number" class="form-control" id="maxRetries" min="0"
                                                    max="5" value="2" placeholder="Number of retry attempts if failed">
                                                <div class="form-text">Recommendation: 2-3 times for efficiency</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="dailyMessageLimit" class="form-label">
                                                    <i class="bi bi-calendar-day"></i> Daily Limit (optional)
                                                </label>
                                                <input type="number" class="form-control" id="dailyMessageLimit" min="0"
                                                    max="1000" value="0" placeholder="0 = unlimited">
                                                <div class="form-text">Limit total messages per day (0 = unlimited)</div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <div class="form-check form-switch mt-4">
                                                    <input class="form-check-input" type="checkbox" id="enableRateLimit"
                                                        checked>
                                                    <label class="form-check-label" for="enableRateLimit">
                                                        <strong>Enable Rate Limiting</strong>
                                                    </label>
                                                </div>
                                                <div class="form-text">Disable for unlimited sending (not recommended)</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="button" class="btn btn-primary" onclick="saveRateLimitSettings()">
                                            <i class="bi bi-save"></i> Save Rate Limiting Settings
                                        </button>
                                        <button type="button" class="btn btn-warning ms-2"
                                            onclick="resetRateLimitSettings()">
                                            <i class="bi bi-arrow-clockwise"></i> Reset to Default
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp Groups Settings Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                </div>

                                <form id="waGroupForm">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-check form-switch mb-3">
                                                <input class="form-check-input" type="checkbox" id="waGroupsEnabled"
                                                    checked>
                                                <label class="form-check-label" for="waGroupsEnabled">
                                                    <strong>Enable Send to Groups</strong>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-12">
                                            <div class="mb-3">
                                                <label for="waGroupIds" class="form-label">
                                                    <i class="bi bi-hash"></i> Group IDs (one per line)
                                                </label>
                                                <textarea class="form-control" id="waGroupIds" rows="4"
                                                    placeholder="1203630xxxxxxxx@g.us\n12036yyyyyyyy@g.us"></textarea>
                                                <div class="form-text">Use WhatsApp group JID, example:
                                                    120363031495796203@g.us. Empty lines will be ignored.</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="button" class="btn btn-primary" onclick="saveWAGroups()">
                                            <i class="bi bi-save"></i> Save Group Settings
                                        </button>
                                        <button type="button" class="btn btn-warning ms-2"
                                            onclick="resetWAGroupsToDefault()">
                                            <i class="bi bi-arrow-clockwise"></i> Reset
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Templates Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                        <i class="bi bi-chat-text"></i> Message Templates
                                    </h4>
                                    <div>
                                        <button class="btn btn-success btn-sm me-2" onclick="enableAllTemplates()">
                                            <i class="bi bi-check-all"></i> Enable All
                                        </button>
                                        <button class="btn btn-danger btn-sm me-2" onclick="disableAllTemplates()">
                                            <i class="bi bi-x-all"></i> Disable All
                                        </button>
                                        <button class="btn btn-primary" onclick="saveAllTemplates()">
                                            <i class="bi bi-save"></i> Save All Templates
                                        </button>
                                    </div>
                                </div>

                                <div class="template-description">
                                    Manage WhatsApp notification templates for different billing events. Use variables
                                    in curly braces {} to insert dynamic data.
                                </div>

                                <!-- Template Forms -->
                                <div id="templateForms">
                                    <!-- Invoice Created Template -->
                                    <div class="mb-4">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h5>📋 Invoice Created Notification</h5>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox"
                                                    id="invoice_created_enabled" checked>
                                                <label class="form-check-label" for="invoice_created_enabled">
                                                    <strong>Enable Notification</strong>
                                                </label>
                                            </div>
                                        </div>
                                        <div class="variable-list">
                                            <strong>Available Variables:</strong>
                                            <span class="variable-item">{customer_name}</span>
                                            <span class="variable-item">{invoice_number}</span>
                                            <span class="variable-item">{amount}</span>
                                            <span class="variable-item">{due_date}</span>
                                            <span class="variable-item">{package_name}</span>
                                            <span class="variable-item">{package_speed}</span>
                                            <span class="variable-item">{notes}</span>
                                        </div>
                                        <textarea class="form-control" id="invoice_created_template" rows="8"
                                            placeholder="Enter template message..."></textarea>
                                        <div class="mt-2">
                                            <button class="btn btn-warning btn-sm"
                                                onclick="testTemplate('invoice_created')">
                                                <i class="bi bi-send"></i> Test Template
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Due Date Reminder Template -->
                                    <div class="mb-4">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h5>⚠️ Due Date Reminder</h5>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox"
                                                    id="due_date_reminder_enabled" checked>
                                                <label class="form-check-label" for="due_date_reminder_enabled">
                                                    <strong>Enable Notification</strong>
                                                </label>
                                            </div>
                                        </div>
                                        <div class="variable-list">
                                            <strong>Available Variables:</strong>
                                            <span class="variable-item">{customer_name}</span>
                                            <span class="variable-item">{invoice_number}</span>
                                            <span class="variable-item">{amount}</span>
                                            <span class="variable-item">{due_date}</span>
                                            <span class="variable-item">{days_remaining}</span>
                                            <span class="variable-item">{package_name}</span>
                                            <span class="variable-item">{package_speed}</span>
                                        </div>
                                        <textarea class="form-control" id="due_date_reminder_template" rows="8"
                                            placeholder="Enter template message..."></textarea>
                                        <div class="mt-2">
                                            <button class="btn btn-warning btn-sm"
                                                onclick="testTemplate('due_date_reminder')">
                                                <i class="bi bi-send"></i> Test Template
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Payment Received Template -->
