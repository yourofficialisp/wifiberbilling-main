<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Detail - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/mobile-sidebar.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Include Billing Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">
                            <i class="bx bx-user"></i> Customer Detail
                        </h1>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/admin/billing/customers">Customers</a></li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    <%= customer.name %>
                                </li>
                            </ol>
                        </nav>
                    </div>

                    <!-- Customer Info Card -->
                    <div class="row">
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bx bx-user-circle"></i> Customer Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <strong>Username:</strong>
                                        <%= customer ? customer.username : 'N/A' %>
                                    </div>
                                    <div class="mb-3">
                                        <strong>Name:</strong>
                                        <%= customer ? customer.name : 'N/A' %>
                                    </div>
                                    <div class="mb-3">
                                        <strong>Phone:</strong>
                                        <%= customer && customer.phone ? customer.phone : '-' %>
                                    </div>
                                    <div class="mb-3">
                                        <button type="button" class="btn btn-outline-warning btn-sm" id="resetPortalPasswordBtn" data-phone="<%= customer && customer.phone ? customer.phone : '' %>">
                                            <i class="bx bx-key"></i> Reset Portal Password (123456)
                                        </button>
                                        <div id="resetPortalPasswordMsg" class="small mt-2" style="display:none;"></div>
                                    </div>
                                    <div class="mb-3">
                                        <strong>Email:</strong>
                                        <%= customer && customer.email ? customer.email : '-' %>
                                    </div>
                                    <div class="mb-3">
                                        <strong>Address:</strong>
                                        <%= customer && customer.address ? customer.address : '-' %>
                                    </div>
                                    <div class="mb-3">
                                        <strong>Status:</strong>
                                        <% if (customer && customer.status==='active' ) { %>
                                            <span class="badge bg-success">Active</span>
                                            <% } else if (customer && customer.status==='inactive' ) { %>
                                                <span class="badge bg-secondary">Inactive</span>
                                                <% } else if (customer && customer.status==='suspended' ) { %>
                                                    <span class="badge bg-warning">Suspended</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Unknown</span>
                                                        <% } %>
                                    </div>
                                    <div class="mb-3">
                                        <strong>Joined:</strong>
                                        <%= customer && customer.join_date ? new
                                            Date(customer.join_date).toLocaleDateString('en-US') : 'N/A' %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bx bx-package"></i> Internet Package
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <% if (customer && customer.package_name) { %>
                                        <div class="mb-3">
                                            <strong>Package Name:</strong>
                                            <%= customer.package_name %>
                                        </div>
                                        <div class="mb-3">
                                            <strong>Speed:</strong>
                                            <%= customer.package_speed %>
                                        </div>
                                        <div class="mb-3">
                                            <strong>Price:</strong> Rp <%= customer.package_price ?
                                                parseFloat(customer.package_price).toLocaleString('en-US') : '0' %>
                                        </div>
                                        <% } else { %>
                                            <div class="alert alert-warning">
                                                <i class="bx bx-alert"></i> Customer does not have an internet package
                                            </div>
                                            <% } %>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Invoices Table -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="bx bx-receipt"></i> Billing History
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-centered table-nowrap table-hover mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Invoice No.</th>
                                                    <th>Package</th>
                                                    <th>Amount</th>
                                                    <th>Status</th>
                                                    <th>Due Date</th>
                                                    <th>Created Date</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (invoices && invoices.length> 0) { %>
                                                    <% invoices.forEach(function(invoice) { %>
                                                        <tr>
                                                            <td>
                                                                <span class="text-body fw-bold">
                                                                    <%= invoice ? invoice.invoice_number : 'N/A' %>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <%= invoice ? invoice.package_name : 'N/A' %>
                                                            </td>
                                                            <td>Rp <%= invoice && invoice.amount ?
                                                                    parseFloat(invoice.amount).toLocaleString('en-US')
                                                                    : '0' %>
                                                            </td>
                                                            <td>
                                                                <% if (invoice && invoice.status==='paid' ) { %>
                                                                    <span class="badge bg-success">Paid</span>
                                                                    <% } else if (invoice && invoice.status==='unpaid' )
                                                                        { %>
                                                                        <% if (invoice.due_date && new
                                                                            Date(invoice.due_date) < new Date()) { %>
                                                                            <span class="badge bg-danger">Overdue</span>
                                                                            <% } else { %>
                                                                                <span class="badge bg-warning">Unpaid</span>
                                                                                <% } %>
                                                                                    <% } else { %>
                                                                                        <span class="badge bg-secondary">Unknown</span>
                                                                                        <% } %>
                                                            </td>
                                                            <td>
                                                                <% if (invoice && invoice.due_date) { %>
                                                                    <% if (new Date(invoice.due_date) < new Date() &&
                                                                        invoice.status==='unpaid' ) { %>
                                                                        <span class="text-danger">
                                                                            <%= new
                                                                                Date(invoice.due_date).toLocaleDateString('en-US')
                                                                                %>
                                                                        </span>
                                                                        <% } else { %>
                                                                            <%= new
                                                                                Date(invoice.due_date).toLocaleDateString('en-US')
                                                                                %>
                                                                                <% } %>
                                                                                    <% } else { %>
                                                                                        N/A
                                                                                        <% } %>
                                                            </td>
                                                            <td>
                                                                <%= invoice && invoice.created_at ? new
                                                                    Date(invoice.created_at).toLocaleDateString('en-US')
                                                                    : 'N/A' %>
                                                            </td>
                                                            <td>
                                                                <% if (invoice) { %>
                                                                    <div class="btn-group" role="group">
                                                                        <button type="button"
                                                                            class="btn btn-sm btn-outline-primary view-invoice-btn"
                                                                            data-id="<%= invoice.id %>"
                                                                            data-bs-toggle="tooltip"
                                                                            data-bs-placement="top"
                                                                            title="View Details">
                                                                            <i
                                                                                class="mdi mdi-file-document-outline"></i>
                                                                        </button>
                                                                        <% if (invoice.status==='unpaid' ) { %>
                                                                            <button type="button"
                                                                                class="btn btn-sm btn-outline-success mark-paid-btn"
                                                                                data-id="<%= invoice.id %>"
                                                                                data-invoice-number="<%= invoice.invoice_number %>"
                                                                                data-amount="<%= invoice.amount %>"
                                                                                data-bs-toggle="tooltip"
                                                                                data-bs-placement="top"
                                                                                title="Mark as Paid">
                                                                                <i class="mdi mdi-cash-check"></i>
                                                                            </button>
                                                                            <% } %>
                                                                                <button type="button"
                                                                                    class="btn btn-sm btn-outline-info print-invoice-btn"
                                                                                    data-id="<%= invoice.id %>"
                                                                                    data-bs-toggle="tooltip"
                                                                                    data-bs-placement="top"
                                                                                    title="Print Invoice">
                                                                                    <i
                                                                                        class="mdi mdi-printer-outline"></i>
                                                                                </button>
                                                                    </div>
                                                                    <% } else { %>
                                                                        <span class="text-muted">N/A</span>
                                                                        <% } %>
                                                            </td>
                                                        </tr>
                                                        <% }); %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="7" class="text-center text-muted">No invoices yet</td>
                                                                </tr>
                                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Trouble Reports Table -->
                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header d-flex align-items-center">
                                    <h5 class="card-title mb-0">
                                        <i class="bi bi-exclamation-triangle me-1"></i> Trouble Report History
                                    </h5>
                                    <span class="badge bg-light text-dark ms-2">
                                        <%= troubleReports && troubleReports.length ? troubleReports.length : 0 %>
                                            reports
                                    </span>
                                    <a href="/admin/trouble" class="btn btn-sm btn-outline-primary ms-auto">Manage All</a>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-centered table-nowrap table-hover mb-0">
                                            <thead>
                                                <tr>
                                                    <th>ID</th>
                                                    <th>Date</th>
                                                    <th>Category</th>
                                                    <th>Location</th>
                                                    <th>Status</th>
                                                    <th>Last Note</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof troubleReports !=='undefined' && troubleReports &&
                                                    troubleReports.length> 0) { %>
                                                    <% troubleReports.slice().reverse().forEach(function(rep) { %>
                                                        <tr>
                                                            <td>#<%= rep.id %>
                                                            </td>
                                                            <td>
                                                                <%= rep.created_at ? new
                                                                    Date(rep.created_at).toLocaleString('en-US') : '-'
                                                                    %>
                                                            </td>
                                                            <td>
                                                                <%= rep.category || '-' %>
                                                            </td>
                                                            <td>
                                                                <%= rep.location || '-' %>
                                                            </td>
                                                            <td>
                                                                <span class="badge <%= 
                                                                rep.status === 'open' ? 'bg-danger' : 
                                                                rep.status === 'in_progress' ? 'bg-warning text-dark' : 
                                                                rep.status === 'resolved' ? 'bg-success' : 
                                                                'bg-secondary' %>">
                                                                    <%= rep.status || '-' %>
                                                                </span>
                                                            </td>
                                                            <td
                                                                style="max-width: 360px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                                <%= rep.notes && rep.notes.length ?
                                                                    rep.notes[rep.notes.length - 1] : '-' %>
                                                            </td>
                                                        </tr>
                                                        <% }); %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="6" class="text-center text-muted">No trouble reports yet</td>
                                                                </tr>
                                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
        </div>
    </div>

    <!-- Mark as Paid Modal -->
    <div class="modal fade" id="markAsPaidModal" tabindex="-1" aria-labelledby="markAsPaidModalLabel"
        aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="markAsPaidModalLabel">Mark as Paid</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="markAsPaidForm">
                    <div class="modal-body">
                        <input type="hidden" id="paidInvoiceId" name="invoice_id">
                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label">Payment Method *</label>
                            <select class="form-select" id="paymentMethod" name="payment_method" required>
                                <option value="">Select Payment Method</option>
                                <option value="cash">Cash</option>
                                <option value="transfer">Bank Transfer</option>
                                <option value="qris">QRIS</option>
                                <option value="ewallet">E-Wallet</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="paymentNotes" class="form-label">Payment Notes</label>
                            <textarea class="form-control" id="paymentNotes" name="notes" rows="3"
                                placeholder="Payment notes (optional)"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Mark as Paid</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        (function () {
            const btn = document.getElementById('resetPortalPasswordBtn');
            const msg = document.getElementById('resetPortalPasswordMsg');
            if (!btn || !msg) return;

            btn.addEventListener('click', async function () {
                const phone = btn.getAttribute('data-phone');
                if (!phone) return;
                if (!confirm('Reset customer portal password to 123456?')) return;

                btn.disabled = true;
                msg.style.display = 'block';
                msg.className = 'small mt-2 text-muted';
                msg.textContent = 'Processing...';

                try {
                    const res = await fetch(`/admin/billing/customers/${encodeURIComponent(phone)}/reset-portal-password`, { method: 'POST' });
                    const data = await res.json().catch(() => ({}));
                    if (!res.ok || !data.success) {
                        msg.className = 'small mt-2 text-danger';
                        msg.textContent = data.message || 'Failed to reset password';
                        return;
                    }
                    msg.className = 'small mt-2 text-success';
                    msg.textContent = data.message || 'Password successfully reset';
                } catch (e) {
                    msg.className = 'small mt-2 text-danger';
                    msg.textContent = 'An error occurred while resetting password';
                } finally {
                    btn.disabled = false;
                }
            });
        })();

        document.addEventListener('DOMContentLoaded', function () {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // View Invoice
            document.addEventListener('click', function (e) {
                if (e.target.closest('.view-invoice-btn')) {
                    const button = e.target.closest('.view-invoice-btn');
                    const id = button.getAttribute('data-id');
                    window.open(`/admin/billing/invoices/${id}`, '_blank');
                }
            });

            // Print Invoice
            document.addEventListener('click', function (e) {
                if (e.target.closest('.print-invoice-btn')) {
                    const button = e.target.closest('.print-invoice-btn');
                    const id = button.getAttribute('data-id');
                    window.open(`/admin/billing/invoices/${id}/print`, '_blank');
                }
            });

            // Mark as Paid
            document.addEventListener('click', function (e) {
                if (e.target.closest('.mark-paid-btn')) {
                    const button = e.target.closest('.mark-paid-btn');
                    const id = button.getAttribute('data-id');
                    const invoiceNumber = button.getAttribute('data-invoice-number');
                    const amount = button.getAttribute('data-amount');

                    document.getElementById('paidInvoiceId').value = id;
                    document.getElementById('markAsPaidModalLabel').textContent = `Mark as Paid - ${invoiceNumber}`;
                    $('#markAsPaidModal').modal('show');
                }
            });
        });

        // Handle mark as paid form submission
        document.getElementById('markAsPaidForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const formData = new FormData(this);
            const data = Object.fromEntries(formData);
            const invoiceId = data.invoice_id;
            const paymentMethod = data.payment_method;
            const notes = data.notes;

            // Validate required fields
            if (!paymentMethod) {
                alert('Please select payment method');
                return;
            }

            // Disable submit button to prevent double submission
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="mdi mdi-loading mdi-spin"></i> Processing...';

            // Get invoice amount first
            fetch(`/admin/billing/api/invoices/${invoiceId}`)
                .then(response => response.json())
                .then(invoiceData => {
                    if (!invoiceData.success) {
                        throw new Error('Failed to get invoice data');
                    }

                    const invoiceAmount = parseFloat(invoiceData.invoice.amount);

                    // Record the payment with correct amount
                    return fetch('/admin/billing/payments', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            invoice_id: invoiceId,
                            amount: invoiceAmount,
                            payment_method: paymentMethod,
                            reference_number: '',
                            notes: notes || ''
                        })
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (!result.success) {
                                throw new Error(result.message || 'Failed to record payment');
                            }
                            // Close modal and reset form
                            $('#markAsPaidModal').modal('hide');
                            document.getElementById('markAsPaidForm').reset();

                            // Show success notification
                            alert('✅ Invoice successfully marked as paid!');

                            // Reload page after a short delay
                            setTimeout(() => location.reload(), 1500);
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            alert('❌ An error occurred while marking invoice as paid');
                        })
                        .finally(() => {
                            // Re-enable submit button
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalText;
                        });
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('❌ An error occurred while marking invoice as paid');
                })
                .finally(() => {
                    // Re-enable submit button
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                });
        });
    </script>

    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'customers' }) %>

        <!-- Bootstrap Bundle with Popper -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
