<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Service Suspension - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/mobile-sidebar.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }

        .suspension-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
        }

        .stats-card {
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            transition: transform 0.3s ease;
        }

        .stats-card:hover {
            transform: translateY(-5px);
        }

        .btn-suspend {
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a52 100%);
            border: none;
            border-radius: 8px;
            color: white;
            transition: all 0.3s ease;
        }

        .btn-restore {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            border: none;
            border-radius: 8px;
            color: white;
            transition: all 0.3s ease;
        }

        .btn-check {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 8px;
            color: white;
            transition: all 0.3s ease;
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/billing-sidebar') %>

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                    <h3 class="mb-4">Settings</h3>

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-4">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'payment-settings' ? 'active' : '' %>"
                                href="/admin/billing/payment-settings">
                                <i class="bi bi-cog"></i> Payment Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'whatsapp-settings' ? 'active' : '' %>"
                                href="/admin/billing/whatsapp-settings">
                                <i class="bi bi-chat-dots"></i> WhatsApp Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'service-suspension' ? 'active' : '' %>"
                                href="/admin/billing/service-suspension">
                                <i class="bi bi-pause-circle"></i> Suspension Settings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'mapping-new' ? 'active' : '' %>"
                                href="/admin/billing/mapping-new">
                                <i class="bi bi-map"></i> Network Mapping
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'genieacs' ? 'active' : '' %>"
                                href="/admin/genieacs">
                                <i class="bi bi-wifi"></i> GenieACS
                            </a>
                        </li>
                    </ul>

                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">
                            <i class="bx bx-pause-circle"></i> Service Suspension
                        </h1>
                    </div>

                    <!-- Service Suspension Overview -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="suspension-card p-4">
                                <h4><i class="bx bx-shield-x me-2"></i>Manage Service Suspension</h4>
                                <p class="mb-0">Automatic system to disable services for customers with overdue payments
                                    using a Mikrotik suspension profile and reactivate after payment.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Statistics Cards -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card stats-card">
                                <div class="card-body text-center">
                                    <i class="bx bx-user-check text-primary" style="font-size: 2rem;"></i>
                                    <h3 class="text-primary" id="activeCustomers">-</h3>
                                    <p class="text-muted mb-0">Active Customers</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card stats-card">
                                <div class="card-body text-center">
                                    <i class="bx bx-pause-circle text-danger" style="font-size: 2rem;"></i>
                                    <h3 class="text-danger" id="suspendedCustomers">-</h3>
                                    <p class="text-muted mb-0">Suspended Customers</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card stats-card">
                                <div class="card-body text-center">
                                    <i class="bx bx-exclamation-triangle text-warning" style="font-size: 2rem;"></i>
                                    <h3 class="text-warning" id="overdueInvoices">-</h3>
                                    <p class="text-muted mb-0">Overdue Invoices</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card stats-card">
                                <div class="card-body text-center">
                                    <i class="bx bx-time text-info" style="font-size: 2rem;"></i>
                                    <h3 class="text-info" id="currentGracePeriod">
                                        <%= appSettings.suspension_grace_period_days || '3' %>
                                    </h3>
                                    <p class="text-muted mb-0">Grace Period (Days)</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Suspension Profileeeeeeeeee Setting -->
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <strong>Select Suspension Profileeeeeeeeee (Mikrotik)</strong>
                                    <div>
                                        <button class="btn btn-sm btn-outline-secondary me-2"
                                            id="reloadIsolirProfileeeeeeeeeesBtn">
                                            <i class="bx bx-refresh me-1"></i>Reload
                                        </button>
                                        <button class="btn btn-sm btn-primary" id="saveIsolirProfileeeeeeeeeeBtn">
                                            <i class="bx bx-save me-1"></i>Save
                                        </button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <label for="isolirProfileeeeeeeeeeSelect" class="form-label">Suspension Profileeeeeeeeee</label>
                                    <select id="isolirProfileeeeeeeeeeSelect" class="form-select">
                                        <option value="default">Loading...</option>
                                    </select>
                                    <small class="text-muted">Used during suspension. Profileeeeeeeeee from Mikrotik with
                                        highlight from active profile in settings.json</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <strong>Grace Period Settings</strong>
                                    <button class="btn btn-sm btn-success" id="saveGracePeriodBtn">
                                        <i class="bx bx-save me-1"></i>Save
                                    </button>
                                </div>
                                <div class="card-body">
                                    <label for="gracePeriodInput" class="form-label">Grace Period (Days)</label>
                                    <input type="number" id="gracePeriodInput" class="form-control" min="1" max="30"
                                        placeholder="Enter number of days">
                                    <small class="text-muted">Number of days after invoice overdue before customer
                                        is automatically suspended. Current: <span id="currentGracePeriod">
                                            <%= appSettings.suspension_grace_period_days || '3' %>
                                        </span> days</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body text-center">
                                    <i class="bx bx-search text-warning" style="font-size: 3rem;"></i>
                                    <h5>Check Overdue Customers</h5>
                                    <p class="text-muted">Check and suspend customers with overdue payments</p>
                                    <button class="btn btn-check w-100" id="checkOverdueBtn">
                                        <i class="bx bx-search me-2"></i>Check & Suspend Overdue
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body text-center">
                                    <i class="bx bx-check-circle text-success" style="font-size: 3rem;"></i>
                                    <h5>Restore Paid Customers</h5>
                                    <p class="text-muted">Reactivate customers who have paid</p>
                                    <button class="btn btn-restore w-100" id="checkPaidBtn">
                                        <i class="bx bx-check me-2"></i>Check & Restore Paid
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body text-center">
                                    <i class="bx bx-refresh text-primary" style="font-size: 3rem;"></i>
                                    <h5>Refresh Statistics</h5>
                                    <p class="text-muted">Update latest statistics</p>
                                    <button class="btn btn-check w-100" id="refreshStatsBtn">
                                        <i class="bx bx-refresh me-2"></i>Refresh Stats
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Suspended Customers Table -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0"><i class="bx bx-pause-circle me-2"></i>Suspended Customers</h5>
                                    <button class="btn btn-sm btn-outline-primary" id="refreshTableBtn">
                                        <i class="bx bx-refresh me-1"></i>Refresh
                                    </button>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-hover" id="suspendedTable">
                                            <thead>
                                                <tr>
                                                    <th>Username</th>
                                                    <th>Name</th>
                                                    <th>Phone</th>
                                                    <th>Package</th>
                                                    <th>Status</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td colspan="6" class="text-center">Loading...</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
        </div>
    </div>

    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'settings' }) %>

        <!-- Toast Container -->
        <div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 9999;"></div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script>
            // Fungsi toast notification (Ensure it exists)
            function showToast(type, title, message, duration = 5000) {
                const toastId = 'toast-' + Date.now();
                const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';
                const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';

                const toastHtml = `
                    <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                        <div class="d-flex">
                            <div class="toast-body">
                                <i class="bi ${iconClass} me-2"></i>
                                <strong>${title}</strong><br>
                                <small>${message}</small>
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                    </div>
                `;

                $('#toast-container').append(toastHtml);
                const toastElement = document.getElementById(toastId);
                const toast = new bootstrap.Toast(toastElement, { delay: duration });
                toast.show();

                toastElement.addEventListener('hidden.bs.toast', () => {
                    toastElement.remove();
                });
            }

            // Load statistics
            function loadStats() {
                $.get('/admin/billing/api/stats', function (response) {
                    const stats = response.data || response;
                    $('#activeCustomers').text(stats.active_customers || 0);
                }).fail(() => {
                    $('#activeCustomers').text('Error');
                });

                $.get('/admin/billing/api/customers', function (response) {
                    const customers = response.customers || response;
                    const suspended = customers.filter(c => c.status === 'suspended').length;
                    $('#suspendedCustomers').text(suspended);
                }).fail(() => {
                    $('#suspendedCustomers').text('Error');
                });

                $.get('/admin/billing/api/overdue', function (overdue) {
                    $('#overdueInvoices').text(overdue.length);
                }).fail(() => {
                    $('#overdueInvoices').text('Error');
                });
            }

            // Load suspended customers table
            function loadSuspendedCustomers() {
                $.get('/admin/billing/api/customers', function (response) {
                    const customers = response.customers || response;
                    const suspended = customers.filter(c => c.status === 'suspended');
                    const tbody = $('#suspendedTable tbody');
                    tbody.empty();

                    if (suspended.length === 0) {
                        tbody.append('<tr><td colspan="6" class="text-center text-muted">No suspended customers</td></tr>');
                        return;
                    }

                    suspended.forEach(customer => {
                        const row = `
                        <tr>
                            <td>${customer.username}</td>
                            <td>${customer.name}</td>
                            <td>${customer.phone || '-'}</td>
                            <td>${customer.package_name || '-'}</td>
                            <td><span class="badge bg-danger">Suspended</span></td>
                            <td>
                                <button class="btn btn-sm btn-restore" onclick="restoreCustomer('${customer.username}')">
                                    <i class="bx bx-check me-1"></i>Restore
                                </button>
                            </td>
                        </tr>
                    `;
                        tbody.append(row);
                    });
                }).fail(() => {
                    $('#suspendedTable tbody').html('<tr><td colspan="6" class="text-center text-danger">Error loading data</td></tr>');
                });
            }

            // Check overdue customers
            $('#checkOverdueBtn').click(function () {
                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bx bx-loader-alt bx-spin me-2"></i>Checking...');

                $.post('/admin/billing/service-suspension/check-overdue', function (response) {
                    if (response.success) {
                        const message = `Checked: ${response.checked || 0}, Suspended: ${response.suspended || 0}, Errors: ${response.errors || 0}`;
                        showToast('success', 'Check Overdue Complete', message);
                        loadStats();
                        loadSuspendedCustomers();
                    } else {
                        showToast('error', 'Error', response.message || 'Unknown error occurred');
                    }
                }).fail(function (xhr) {
                    const response = xhr.responseJSON || {};
                    showToast('error', 'Error', response.message || 'Request failed');
                }).always(function () {
                    btn.prop('disabled', false).html('<i class="bx bx-search me-2"></i>Check & Suspend Overdue');
                });
            });

            // Check paid customers
            $('#checkPaidBtn').click(function () {
                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bx bx-loader-alt bx-spin me-2"></i>Checking...');

                $.post('/admin/billing/service-suspension/check-paid', function (response) {
                    if (response.success) {
                        const message = `Checked: ${response.checked || 0}, Restored: ${response.restored || 0}, Errors: ${response.errors || 0}`;
                        showToast('success', 'Check Paid Complete', message);
                        loadStats();
                        loadSuspendedCustomers();
                    } else {
                        showToast('error', 'Error', response.message || 'Unknown error occurred');
                    }
                }).fail(function (xhr) {
                    const response = xhr.responseJSON || {};
                    showToast('error', 'Error', response.message || 'Request failed');
                }).always(function () {
                    btn.prop('disabled', false).html('<i class="bx bx-check me-2"></i>Check & Restore Paid');
                });
            });

            // Refresh stats
            $('#refreshStatsBtn').click(function () {
                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bx bx-loader-alt bx-spin me-2"></i>Loading...');

                loadStats();
                loadGracePeriod(); // Also reload grace period

                setTimeout(() => {
                    btn.prop('disabled', false).html('<i class="bx bx-refresh me-2"></i>Refresh Stats');
                    showToast('success', 'Refreshed', 'Statistics updated');
                }, 1000);
            });

            // Refresh table
            $('#refreshTableBtn').click(function () {
                loadSuspendedCustomers();
                showToast('info', 'Refreshed', 'Table updated');
            });

            // Restore customer
            function restoreCustomer(username) {
                if (!username || username.trim() === '') {
                    showToast('error', 'Error', 'Invalid username');
                    return;
                }

                if (!confirm(`Are you sure you want to restore service for customer ${username}?`)) return;

                const reason = prompt('Enter reason for unsuspend (optional):', 'Manual restore');
                if (reason === null) return; // user canceled prompt

                // Show loading state
                showToast('info', 'Processing', `Activating service for ${username}...`);

                $.post(`/admin/billing/service-suspension/restore/${username}`, { reason }, function (response) {
                    if (response.success) {
                        const r = (response.reason || reason || '').trim();
                        const msg = r ? `Service ${username} activated. Reason: ${r}` : `Service ${username} successfully activated`;
                        showToast('success', 'Service Restored', msg);
                        loadStats();
                        loadSuspendedCustomers();
                    } else {
                        showToast('error', 'Error', response.message || 'Failed to activate service');
                    }
                }).fail(function (xhr) {
                    const response = xhr.responseJSON || {};
                    showToast('error', 'Error', response.message || 'Request failed');
                });
            }

            // Initialize
            $(document).ready(function () {
                // Load isolir profiles and current setting
                loadIsolirProfileeeeeeeeees();
                loadCurrentIsolirProfileeeeeeeeee();
                loadGracePeriod();
                loadStats();
                loadSuspendedCustomers();
            });

            // Load Mikrotik PPPoE profiles with active profile highlighting from settings.json
            function loadIsolirProfileeeeeeeeees(selected) {
                const sel = document.getElementById('isolirProfileeeeeeeeeeSelect');
                if (!sel) return;
                sel.innerHTML = '<option>Loading...</option>';

                // First, get active profile from settings.json
                fetch('/admin/billing/service-suspension/isolir-profile')
                    .then(r => r.json())
                    .then(settingsData => {
                        const currentIsolirProfileeeeeeeeee = (settingsData && settingsData.success) ? settingsData.isolir_profile : 'isolir';

                        // Then load profiles from Mikrotik API
                        return fetch('/admin/mikrotik/profiles/api')
                            .then(r => r.json())
                            .then(data => {
                                const names = Array.from(new Set(((data && data.profiles) || []).map(p => p.name).filter(Boolean)));

                                // Make sure profile from settings.json is in the list
                                if (currentIsolirProfileeeeeeeeee && !names.includes(currentIsolirProfileeeeeeeeee)) {
                                    names.unshift(currentIsolirProfileeeeeeeeee);
                                }

                                sel.innerHTML = '';
                                names.forEach(n => {
                                    const opt = document.createElement('option');
                                    opt.value = n;

                                    // Mark profile that is currently active from settings.json
                                    if (n === currentIsolirProfileeeeeeeeee) {
                                        opt.textContent = n + ' (Active)';
                                        opt.selected = true;
                                    } else {
                                        opt.textContent = n;
                                    }

                                    sel.appendChild(opt);
                                });

                                // Set selected value if there is a parameter, but don't override active profile
                                if (selected && selected !== currentIsolirProfileeeeeeeeee) {
                                    sel.value = selected;
                                }
                            })
                            .catch(err => {
                                console.error('Load isolir profiles error:', err);
                                // Fallback: create dropdown with profile from settings.json
                                sel.innerHTML = '';
                                const opt = document.createElement('option');
                                opt.value = currentIsolirProfileeeeeeeeee;
                                opt.textContent = currentIsolirProfileeeeeeeeee + ' (Active)';
                                opt.selected = true;
                                sel.appendChild(opt);
                                showToast('warning', 'Fallback', 'Using profile from settings because failed to load from Mikrotik');
                            });
                    })
                    .catch(err => {
                        console.error('Error loading current isolir profile:', err);
                        // If failed to load settings, still load from Mikrotik
                        fetch('/admin/mikrotik/profiles/api')
                            .then(r => r.json())
                            .then(data => {
                                const names = Array.from(new Set(((data && data.profiles) || []).map(p => p.name).filter(Boolean)));
                                if (!names.includes('isolir')) names.unshift('isolir');
                                sel.innerHTML = '';
                                names.forEach(n => {
                                    const opt = document.createElement('option');
                                    opt.value = n;
                                    opt.textContent = n;
                                    sel.appendChild(opt);
                                });
                                if (selected) sel.value = selected;
                            })
                            .catch(err => {
                                console.error('Load isolir profiles error:', err);
                                sel.innerHTML = '<option value="isolir">isolir</option>';
                                showToast('error', 'Failed', 'Failed to load Mikrotik profiles');
                            });
                    });
            }

            // Get current isolir profile setting
            function loadCurrentIsolirProfileeeeeeeeee() {
                fetch('/admin/billing/service-suspension/isolir-profile')
                    .then(r => r.json())
                    .then(data => {
                        if (data && data.success) {
                            const current = data.isolir_profile || 'isolir';
                            // ensure options exist then update display
                            const sel = document.getElementById('isolirProfileeeeeeeeeeSelect');
                            if (sel && sel.options.length > 0) {
                                // Update display of active profile without changing dropdown structure
                                for (let i = 0; i < sel.options.length; i++) {
                                    const option = sel.options[i];
                                    if (option.value === current) {
                                        option.textContent = current + ' (Active)';
                                        // Make sure it remains selected
                                        sel.value = current;
                                    } else if (option.textContent.includes(' (Active)')) {
                                        option.textContent = option.value;
                                    }
                                }
                            }
                            else {
                                loadIsolirProfileeeeeeeeees(current);
                            }
                            // mark as ready so next change is considered user action
                            isolirSelectReady = true;
                        }
                    })
                    .catch(() => { });
            }

            // Save isolir profile
            $('#saveIsolirProfileeeeeeeeeeBtn').click(function () {
                const sel = document.getElementById('isolirProfileeeeeeeeeeSelect');
                if (!sel) return;
                const value = sel.value || 'isolir';
                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bx bx-loader-alt bx-spin me-1"></i>Saving...');
                fetch('/admin/billing/service-suspension/isolir-profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
                    body: new URLSearchParams({ isolir_profile: value }).toString()
                }).then(r => r.json()).then(data => {
                    if (data && data.success) {
                        showToast('success', 'Saved', `Suspension profile set to: ${value}`);
                        // Update display after successful save
                        setTimeout(() => {
                            const sel = document.getElementById('isolirProfileeeeeeeeeeSelect');
                            if (sel) {
                                for (let i = 0; i < sel.options.length; i++) {
                                    const option = sel.options[i];
                                    if (option.value === value) {
                                        option.textContent = value + ' (Active)';
                                        option.selected = true;
                                    } else if (option.textContent.includes(' (Active)')) {
                                        option.textContent = option.value;
                                    }
                                }
                            }
                        }, 100);
                    } else {
                        showToast('error', 'Failed', data.message || 'Failed to save');
                    }
                }).catch(err => {
                    showToast('error', 'Failed', 'Failed to save');
                }).finally(() => {
                    btn.prop('disabled', false).html('<i class="bx bx-save me-1"></i>Save');
                });
            });

            // Autosave when profile selection changes
            let isolirSelectReady = false;
            $(document).on('change', '#isolirProfileeeeeeeeeeSelect', function () {
                if (!isolirSelectReady) return; // avoid trigger during initialization
                const value = this.value || 'isolir';
                fetch('/admin/billing/service-suspension/isolir-profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
                    body: new URLSearchParams({ isolir_profile: value }).toString()
                }).then(r => r.json()).then(data => {
                    if (data && data.success) {
                        showToast('success', 'Saved', `Suspension profile set to: ${value}`);
                        // Update display after successful autosave
                        setTimeout(() => {
                            const sel = document.getElementById('isolirProfileeeeeeeeeeSelect');
                            if (sel) {
                                for (let i = 0; i < sel.options.length; i++) {
                                    const option = sel.options[i];
                                    if (option.value === value) {
                                        option.textContent = value + ' (Active)';
                                        option.selected = true;
                                    } else if (option.textContent.includes(' (Active)')) {
                                        option.textContent = option.value;
                                    }
                                }
                            }
                        }, 100);
                    } else {
                        showToast('error', 'Failed', data.message || 'Failed to save');
                    }
                }).catch(() => {
                    showToast('error', 'Failed', 'Failed to save');
                });
            });

            // Reload profiles button
            $('#reloadIsolirProfileeeeeeeeeesBtn').click(function () {
                // Get current value from settings.json then reload profiles with that selection
                fetch('/admin/billing/service-suspension/isolir-profile')
                    .then(r => r.json())
                    .then(data => {
                        const current = (data && data.success && data.isolir_profile) ? data.isolir_profile : (document.getElementById('isolirProfileeeeeeeeeeSelect')?.value || 'isolir');
                        loadIsolirProfileeeeeeeeees(current);
                        // After loading, make sure active profile remains highlighted
                        setTimeout(() => {
                            const sel = document.getElementById('isolirProfileeeeeeeeeeSelect');
                            if (sel) {
                                for (let i = 0; i < sel.options.length; i++) {
                                    const option = sel.options[i];
                                    if (option.value === current) {
                                        option.textContent = current + ' (Active)';
                                        option.selected = true;
                                    } else if (option.textContent.includes(' (Active)')) {
                                        option.textContent = option.value;
                                    }
                                }
                            }
                        }, 300);
                    })
                    .catch(() => {
                        const current = document.getElementById('isolirProfileeeeeeeeeeSelect')?.value;
                        loadIsolirProfileeeeeeeeees(current);
                    });
            });

            // Load current grace period setting
            function loadGracePeriod() {
                fetch('/admin/billing/service-suspension/grace-period')
                    .then(r => r.json())
                    .then(data => {
                        if (data && data.success) {
                            const current = data.grace_period_days || '3';
                            document.getElementById('gracePeriodInput').value = current;
                            document.getElementById('currentGracePeriod').textContent = current;
                        }
                    })
                    .catch(err => {
                        console.error('Error loading grace period:', err);
                        // Set default value
                        document.getElementById('gracePeriodInput').value = '3';
                        document.getElementById('currentGracePeriod').textContent = '3';
                    });
            }

            // Save grace period
            $('#saveGracePeriodBtn').click(function () {
                const input = document.getElementById('gracePeriodInput');
                const value = input.value.trim();

                if (!value || isNaN(value) || parseInt(value) < 1 || parseInt(value) > 30) {
                    showToast('error', 'Error', 'Grace period must be between 1-30 days');
                    return;
                }

                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bx bx-loader-alt bx-spin me-1"></i>Saving...');

                fetch('/admin/billing/service-suspension/grace-period', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
                    body: new URLSearchParams({ grace_period_days: value }).toString()
                }).then(r => r.json()).then(data => {
                    if (data && data.success) {
                        showToast('success', 'Saved', `Grace period set to: ${value} days`);
                        loadGracePeriod(); // Reload to update display
                    } else {
                        showToast('error', 'Failed', data.message || 'Failed to save');
                    }
                }).catch(err => {
                    showToast('error', 'Failed', 'Failed to save');
                }).finally(() => {
                    btn.prop('disabled', false).html('<i class="bx bx-save me-1"></i>Save');
                });
            });
        </script>

</body>

</html>